    // ==========================================
    try {
        if (typeof affectedRetailers !== 'undefined' && affectedRetailers.length > 0) {
            let benefitNotificationQueue = [];
            let phoneColIdx = custMap["phone"] || 12; // Column M का इंडेक्स

            for (let b = 0; b < affectedRetailers.length; b++) {
