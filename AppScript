function getWeeklyPaymentForShop(shopName, salesData, daysAgo) {
  var targetDate = getStartDateDaysAgo(daysAgo);
  var totalPaid = 0;
  
  // Reverse loop for execution speed (O(N) safe)
  for (var s = salesData.length - 1; s >= 1; s--) {
    if (!salesData[s][0]) continue;
    
    var sDate = new Date(salesData[s][0]);
    if (sDate < targetDate) break; // Exit loop immediately when older than 'daysAgo'

    var sShop = (salesData[s][1] || "").toString().trim();
    var sType = (salesData[s][2] || "").toString().trim().toUpperCase();
    
    if (sShop === shopName && sType === "PAYMENT") {
      totalPaid += Math.abs(toNumber(salesData[s][5]));
    }
  }
  
  return totalPaid;
}
