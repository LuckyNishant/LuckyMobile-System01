function getRecoveryTarget(due) {
  if (due <= 100) return 0; // Tiny dues ignored for pressure
  if (due <= 500) return due; // Small accounts: exact amount
  let calc = Math.ceil((due * 0.20) / 100) * 100; // Round UP to nearest 100
  return Math.min(calc, due); // Safe sanity check: never exceed due
}

function getPurchaseTarget(due) {
  if (due <= 0) return 0;
  let calc = Math.ceil((due * 0.15) / 100) * 100;
  if (calc < 500 && due > 1000) calc = 500; // Realistic minimum floor for larger accounts
  return calc;
}

function roundMarketPrice(price) {
  let p = Math.ceil(price);
  let rem = p % 5;
  if (rem === 0) return p;
  return p + (5 - rem);
}

function calculateDynamicTier(shopName, pending, status, salesData, returnData) {
    if (status.includes("BLOCK") || status.includes("DEAD")) return "Restricted (Cash-Only) 🚫";
    
    let today = new Date();
    let buy_30 = 0, buy_7 = 0, ret_7 = 0, buy_14 = 0, ret_14 = 0, buy_21 = 0, ret_21 = 0;
    let paid_7 = 0, paid_14 = 0, paid_21 = 0;

    for (let s = salesData.length - 1; s >= 1; s--) {
        if (!salesData[s][0]) continue;
        let sDate = new Date(salesData[s][0]);
        let daysAgo = Math.floor((today.getTime() - sDate.getTime()) / 86400000);
        if (daysAgo < 0) daysAgo = 0;
        if (daysAgo > 30) break; 

        if (salesData[s][1] === shopName) {
            let sType = (salesData[s][2] || "").toString().trim().toUpperCase();
            let sAmt = toNumber(salesData[s][5]);

            if (sType === "PAYMENT") {
                if (daysAgo <= 7) paid_7 += Math.abs(sAmt);
                if (daysAgo <= 14) paid_14 += Math.abs(sAmt);
                if (daysAgo <= 21) paid_21 += Math.abs(sAmt);
            } else if (!sType.includes("[CANCEL]")) {
                if (daysAgo <= 7) buy_7 += sAmt;
                if (daysAgo <= 14) buy_14 += sAmt;
                if (daysAgo <= 21) buy_21 += sAmt;
                if (daysAgo <= 30) buy_30 += sAmt;
            }
        }
    }

    for (let r = returnData.length - 1; r >= 1; r--) {
        if (!returnData[r][0]) continue;
        let rDate = new Date(returnData[r][0]);
        let daysAgo = Math.floor((today.getTime() - rDate.getTime()) / 86400000);
        if (daysAgo < 0) daysAgo = 0;
        if (daysAgo > 21) break;

        if (returnData[r][1] === shopName) {
            let rAmt = (returnData[r][6] !== "" && returnData[r][6] !== undefined) ? toNumber(returnData[r][6]) : toNumber(returnData[r][5]);
            
            if (daysAgo <= 7) ret_7 += rAmt;
            if (daysAgo <= 14) ret_14 += rAmt;
            if (daysAgo <= 21) ret_21 += rAmt;
        }
    }

    if (pending <= 0) {
        return (buy_30 > 0) ? "Premium Gold 👑" : "Normal 🟢";
    }

    let netBuy7 = Math.max(0, buy_7 - ret_7);
    let netBuy14 = Math.max(0, buy_14 - ret_14);
    let netBuy21 = Math.max(0, buy_21 - ret_21);

    let reqPay = getRecoveryTarget(pending);
    let reqBuy = getPurchaseTarget(pending);

    let isFresh7 = (netBuy7 >= pending);
    let isFresh14 = (netBuy14 >= pending);
    let isFresh21 = (netBuy21 >= pending);

    if ((paid_7 >= reqPay || isFresh7) && netBuy7 >= reqBuy) return "Premium Gold 👑";
    if ((paid_14 >= reqPay || isFresh14) && netBuy14 >= reqBuy) return "Silver Hold 🛡️";
    if ((paid_21 >= reqPay || isFresh21) && netBuy21 >= reqBuy) return "Normal 🟢";
    
    return "Restricted (Cash-Only) 🚫";
}

