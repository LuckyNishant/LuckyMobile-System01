function batchWrite(sheet, rows) {
  if (rows && rows.length > 0) {
    let startRow = sheet.getLastRow();
    sheet.getRange(startRow + 1, 1, rows.length, rows[0].length).setValues(rows);
    SpreadsheetApp.flush();
    if (sheet.getLastRow() === startRow) {
       throw new Error("Write failed for sheet: " + sheet.getName());
    }
  }
}

function buildStockMap(stockData) {
  let stockMap = {};
  if (stockData.length === 0) return stockMap;
  let headers = stockData[0].map(h => (h || "").toString().trim().toLowerCase());
  
  // 🛡️ DYNAMIC COLUMN SCANNER: Exact spelling not required anymore
  const findCol = (keywords) => {
    for (let i = 0; i < headers.length; i++) {
      for (let k = 0; k < keywords.length; k++) {
        if (headers[i].includes(keywords[k])) return i;
      }
    }
    return -1;
  };

  // सिर्फ कीवर्ड से कॉलम ढूंढेगा
  let cashCol = findCol(["cash"]);
  let silverCol = findCol(["silver"]);
  let goldCol = findCol(["gold"]);
  let premCol = findCol(["premium", "prem"]);
  let cpCol = findCol(["actual cp", "cp", "cost"]);
  if (cpCol === -1) cpCol = 6; 

  for (let i = 1; i < stockData.length; i++) {
    let officialName = stockData[i][0];
    if (!officialName) continue;
    
    let basePrice = toNumber(stockData[i][2]);
    let stockQty = toNumber(stockData[i][1]); 
    let universalText = stockData[i][3] ? stockData[i][3].toString() : "";
    let keywordText = stockData[i][4] ? stockData[i][4].toString() : "";
    
    let actualCP = toNumber(stockData[i][cpCol]); 
    if (actualCP === 0 && basePrice > 0) actualCP = basePrice / 1.1; 

    // 👉 FIX: Strict Number Check. अगर कॉलम मिला और उसमें अमाउंट लिखा है, तभी वह रेट लगेगा वरना Base Price
    let cashP = (cashCol > -1 && toNumber(stockData[i][cashCol]) > 0) ? toNumber(stockData[i][cashCol]) : basePrice;
    let silverP = (silverCol > -1 && toNumber(stockData[i][silverCol]) > 0) ? toNumber(stockData[i][silverCol]) : basePrice;
    let goldP = (goldCol > -1 && toNumber(stockData[i][goldCol]) > 0) ? toNumber(stockData[i][goldCol]) : basePrice;
    let premP = (premCol > -1 && toNumber(stockData[i][premCol]) > 0) ? toNumber(stockData[i][premCol]) : basePrice;
    
    let rowObj = {
      name: officialName.toString(), price: basePrice, stock: stockQty,
      cashPrice: cashP, silverPrice: silverP, goldPrice: goldP, premiumPrice: premP,
      rowIndex: i + 1, universal: universalText, cp: actualCP
    };
    
    let allKeywords = [officialName, universalText, keywordText].join(",").split(",");
    for (let k = 0; k < allKeywords.length; k++) {
      let cleanK = normalizeKey(allKeywords[k]);
      if (cleanK && !stockMap[cleanK]) stockMap[cleanK] = rowObj; 
    }
  }
  return stockMap;
}

function normalizeKey(text) { return (text || "").toString().toLowerCase().replace(/[^a-z0-9]/g, ""); }

function toNumber(value) {
  if (typeof value === "number") return value;
  let cleaned = (value || "").toString().replace(/[\s,]/g, "");
  if (cleaned === "") return 0;
  let n = Number(cleaned);
  return isNaN(n) ? 0 : n;
}

function isNumericToken(value) {
  let cleaned = (value || "").toString().replace(/[\s,]/g, "");
  return cleaned !== "" && !isNaN(Number(cleaned));
}

function formatMoney(n) { 
  let num = Math.round(toNumber(n));
  if (num < 0) return "-₹" + Math.abs(num).toLocaleString("en-IN");
  return "₹" + num.toLocaleString("en-IN"); 
}

function getStartDateDaysAgo(days) {
