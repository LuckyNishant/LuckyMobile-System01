    // ==========================================
    // 14. PRICE CHECK ENGINE
    // ==========================================
    var priceRegex = /^@?(price|रेट|rate|folder|combo|ret|pp|rs)\b/i;
    if (priceRegex.test(userMsg)) {
      var pParts = lines[0].trim().split(/\s+/);
      var isCashMode = false;
      var cleanParts = [];
      
      for (var pt = 0; pt < pParts.length; pt++) {
        if (pParts[pt].toUpperCase() === "CASH") isCashMode = true;
        else cleanParts.push(pParts[pt]);
      }
      
      var pShopId = null;
      var queryStartIndex = 1;
      
      if (!isCashMode) {
