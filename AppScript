function getWTDStats(shopName, salesData, returnData) {
  let todayDate = new Date();
  let dayNum = todayDate.getDay() || 7; 
  let startOfWeek = new Date(todayDate);
  startOfWeek.setDate(todayDate.getDate() - (dayNum - 1));
  startOfWeek.setHours(0, 0, 0, 0);

  let stats = { paidWTD: 0, boughtWTD: 0, returnedWTD: 0, netBoughtWTD: 0 };

  for (let s = salesData.length - 1; s >= 1; s--) {
    if (!salesData[s][0]) continue;
    let rDate = new Date(salesData[s][0]);
    if (rDate < startOfWeek) break; 

    if (salesData[s][1] === shopName) {
      let rType = (salesData[s][2] || "").toString().toUpperCase();
      let rAmt = toNumber(salesData[s][5]);
      if (rType === "PAYMENT") stats.paidWTD += Math.abs(rAmt);
      else if (rType.indexOf("[CANCEL]") === -1) stats.boughtWTD += rAmt;
    }
  }

  for (let r = returnData.length - 1; r >= 1; r--) {
    if (!returnData[r][0]) continue;
    let rrDate = new Date(returnData[r][0]);
    if (rrDate < startOfWeek) break;

    if (returnData[r][1] === shopName) {
      let rrAmt = (returnData[r][6] !== "" && returnData[r][6] !== undefined) ? toNumber(returnData[r][6]) : toNumber(returnData[r][5]);
      stats.returnedWTD += rrAmt;
    }
  }

  stats.netBoughtWTD = Math.max(0, stats.boughtWTD - stats.returnedWTD);
  return stats;
}

