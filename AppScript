function setupUniversalModelsTrigger() {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === "sendMonthlyUniversalModelsPush") {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
  
  // हर महीने की 29 तारीख को शाम 5 baje (17:00) ऑटो-रन होगा
  ScriptApp.newTrigger("sendMonthlyUniversalModelsPush")
    .timeBased()
    .onMonthDay(29)
    .atHour(17)
    .create();
}

function sendMonthlyUniversalModelsPush() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    
    var salesSheet = ss.getSheetByName("Sales");
    var customersSheet = ss.getSheetByName("Customers");
    var stockSheet = ss.getSheetByName("Live_Stock");
    
    if (!salesSheet || !customersSheet || !stockSheet) {
      Logger.log("Missing Sheets for Universal Models Push.");
      return;
    }
    
    var today = new Date();
    var thirtyDaysAgo = new Date();
    thirtyDaysAgo.setDate(today.getDate() - 30);
    
    var salesData = salesSheet.getDataRange().getValues();
    var modelSalesQty = {};
    
    for (var i = 1; i < salesData.length; i++) {
      var sDate = new Date(salesData[i][0]); // Date (Col A)
      var modelName = (salesData[i][2] || "").toString().trim(); // Model (Col C)
      var qty = parseFloat(salesData[i][3]) || 0; // Qty (Col D)
      
      if (sDate >= thirtyDaysAgo && modelName !== "" && modelName.toUpperCase() !== "PAYMENT" && !modelName.toUpperCase().includes("CANCEL")) {
        if (!modelSalesQty[modelName]) {
          modelSalesQty[modelName] = 0;
        }
        modelSalesQty[modelName] += qty;
      }
    }
    
    var stockData = stockSheet.getDataRange().getValues();
    var universalScores = [];
    
    var stockHeaders = stockData[0].map(function(h) { return h.toString().trim().toUpperCase(); });
    var stockIdx = stockHeaders.indexOf("STOCK");
    if (stockIdx === -1) stockIdx = stockHeaders.indexOf("QTY");
    
    for (var k = 1; k < stockData.length; k++) {
      var sModel = (stockData[k][0] || "").toString().trim();
      var searchKeywords = (stockData[k][4] || "").toString().trim();
      var currentStock = (stockIdx > -1) ? (parseFloat(stockData[k][stockIdx]) || 0) : 1;
      
      if (sModel !== "" && searchKeywords !== "" && searchKeywords.includes(",")) {
        var compatibilityCount = searchKeywords.split(",").length;
        var salesQty = modelSalesQty[sModel] || 0;
        
        // STRICT FILTER: Sale honi chahiye AUR Stock 0 se jyada hona chahiye
        if (salesQty > 0 && currentStock > 0) {
          var score = compatibilityCount * salesQty;
          var cleanKeywords = searchKeywords;
          var sModelLower = sModel.toLowerCase();
          if (cleanKeywords.toLowerCase().startsWith(sModelLower)) {
              cleanKeywords = cleanKeywords.substring(sModelLower.length).trim();
          }
          if(cleanKeywords === "") cleanKeywords = searchKeywords;
          
          universalScores.push({ model: sModel, score: score, keywords: cleanKeywords });
        }
      }
    }
    
    var scriptProps = PropertiesService.getScriptProperties();
    var lastMonthModelsStr = scriptProps.getProperty("LAST_UNIVERSAL_MODELS");
    var lastMonthModels = [];
    if (lastMonthModelsStr) {
      lastMonthModels = JSON.parse(lastMonthModelsStr);
    }
    
    universalScores.sort(function(a, b) {
      return b.score - a.score;
    });
    
    var finalTopModels = [];
    var modelsToSave = [];
    
    for (var s = 0; s < universalScores.length; s++) {
      var candidate = universalScores[s];
      if (lastMonthModels.indexOf(candidate.model) === -1) {
        finalTopModels.push(candidate);
        modelsToSave.push(candidate.model);
      }
      if (finalTopModels.length === 5) break;
    }
    
    if (finalTopModels.length === 0) return;
    
    scriptProps.setProperty("LAST_UNIVERSAL_MODELS", JSON.stringify(modelsToSave));
    
    var modelListString = "";
    for (var m = 0; m < finalTopModels.length; m++) {
      modelListString += "▪️ *" + finalTopModels[m].model + "* 👉 (" + finalTopModels[m].keywords + " आदि में भी)\n";
    }
    
    var customersData = customersSheet.getDataRange().getValues();
    var map = getColMap(customersData[0]);
    var pushQueue = [];
    
    for (var j = 1; j < customersData.length; j++) {
      var shopName = (customersData[j][map.name] || "").toString().trim();
      var rawPhone = (customersData[j][map.phone] || "").toString().trim();
      var tier = (customersData[j][map.tier] || "").toString().toUpperCase();
      
      var rowString = customersData[j].join(" ").toUpperCase();
      if (rowString.includes("BLOCK") || rowString.includes("DEAD") || rowString.includes("LEGAL")) continue;
      
      var cleanPhone = rawPhone.replace(/[^0-9]/g, "");
      if (cleanPhone.length < 10) continue;
      var phone = cleanPhone.length === 10 ? "91" + cleanPhone : "91" + cleanPhone.slice(-10);
      
      var msg = "भैया " + shopName + " 😊\n" +
                "📦 अभी मार्केट में सबसे ज्यादा movement वाले Super Version यूनिवर्सल मॉडल्स:\n\n" +
                modelListString + "\n" +
                "⚡ ये normal यूनिवर्सल मॉडल नहीं हैं।\n" +
                "मार्केट में ज़्यादातर जगह single model वाले पार्ट मिलते हैं, लेकिन लक्की मोबाइल पर ऐसे Super Version models रखे जाते हैं जो एक साथ कई models में perfectly चलते हैं।\n\n" +
                "📦 फायदा क्या रहता है?\n" +
                "✅ एक मॉडल से कई customer cover\n" +
                "✅ dead stock का risk कम\n" +
                "✅ बार-बार अलग model नहीं रखना पड़ता\n" +
                "✅ customer खाली लौटने के chances कम\n" +
                "✅ fast movement बनी रहती है\n\n" +
                "अभी कई दुकानदार counter पर पहले से ये models maintain करके fast rotation निकाल रहे हैं 😊\n\n";
      
      if (tier.includes("PREMIUM GOLD")) {
        msg += "👑 आपका Premium रोटेशन चालू है, तो इन models पर कम रेट और price-drop protection का फायदा भी आपके खाते में लगातार active रहेगा।";
      } else {
        msg += "👑 अपना Premium रोटेशन चालू रखें, ताकि इन models पर कम रेट और price-drop protection का फायदा आपके खाते में लगातार active रहे।";
      }
      
      pushQueue.push({ phone: phone, message: msg });
    }
    
    // नेटिव फंक्शन के जरिए सीक्वेंशियल ब्रॉडकास्ट
    if (pushQueue.length > 0) {
      pushWebhooksSequential(pushQueue);
    }
    
  } catch (error) {
    Logger.log("Error in Monthly Universal Push: " + error.toString());
  }
}
