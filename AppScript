      return reply("⚠ लेज़र अपडेट में कुछ एरर आए। सिंक लॉग चेक करें।\n\n" + stockupLogs.join("\n"));
    } // 👈 यह ब्रैकेट अब अपनी सही जगह पर है, जिससे स्ट्रक्चर नहीं टूटेगा

    // ==========================================
    // 🟢 SUCCESS PATHWAY
    // ==========================================
    var finalReplyMsg = "✅ स्टॉक अपडेट (BULK)\n\n" + stockupLogs.join("\n");
    if (walletAlerts.length > 0) {
        finalReplyMsg += "\n\n🔥 *प्रीमियम वॉलेट अपडेट्स* 🔥\n" + walletAlerts.join("\n") + "\n(एक्सपायरी: 30 दिन)";
    }

    logAudit("INBOUND_STOCKUP", "SYSTEM", sender, "Bulk Stocked Up", "SUCCESS");

    // ==========================================
