              liveStockSheet.getRange(vi.rowIndex, 3).setValue(vi.baseSP);      // C: Base SP
              liveStockSheet.getRange(vi.rowIndex, 7).setValue(vi.newAvgCP);    // G: Actual CP
              liveStockSheet.getRange(vi.rowIndex, 8).setValue(vi.premiumSP);   // H: Cash Avg (Mirror)
              liveStockSheet.getRange(vi.rowIndex, 9).setValue(vi.silverSP);    // I: Silver Price
              liveStockSheet.getRange(vi.rowIndex, 10).setValue(vi.premiumSP);  // J: Gold Price (Comp)
              liveStockSheet.getRange(vi.rowIndex, 11).setValue(vi.premiumSP);  // K: Premium Price
              
              stockupMutations.liveStock++; 
          } catch (err) { syncErrors.push([new Date(), "STOCKUP", vi.model, vi.qtyIn, err.toString()]); }
        }

        // WRITE PHASE 2: WALLETS
        var walletAlerts = [];
        for (var rowStr in walletUpdates) {
            var wData = walletUpdates[rowStr];
            try {
                custSheet.getRange(Number(rowStr), wData.walletCol).setValue(wData.newWallet);
                custSheet.getRange(Number(rowStr), wData.expiryCol).setValue(globalExpiryDate);
                walletAlerts.push("💳 " + wData.shopName + " (+" + formatMoney(wData.refundAdded) + ")");
                
                // 🚀 LIVE WALLET BENEFIT DATA CAPTURE (MAPPED CORRECTLY)
                if (typeof affectedRetailers === 'undefined') affectedRetailers = [];
                affectedRetailers.push({
