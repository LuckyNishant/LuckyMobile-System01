// ==========================================
// 🛠️ DYNAMIC COLUMN MAPPING (NO HARDCODING)
// ==========================================
function getColMap(headers) {
  const h = headers.map(x => (x || "").toString().trim().toLowerCase());
  return {
    id: h.indexOf("id") > -1 ? h.indexOf("id") : 0,
    name: h.indexOf("shop_name") > -1 ? h.indexOf("shop_name") : (h.indexOf("name") > -1 ? h.indexOf("name") : 1),
    phone: h.indexOf("phone") > -1 ? h.indexOf("phone") : (h.indexOf("whatsapp") > -1 ? h.indexOf("whatsapp") : 2),
    pending: h.indexOf("current_pending") > -1 ? h.indexOf("current_pending") : (h.indexOf("due") > -1 ? h.indexOf("due") : 5),
    status: h.indexOf("status") > -1 ? h.indexOf("status") : 8,
    system_override: h.indexOf("system_override") > -1 ? h.indexOf("system_override") : -1,
    tier: h.indexOf("tier") > -1 ? h.indexOf("tier") : 9,
    streak: h.indexOf("streak") > -1 ? h.indexOf("streak") : 10,
    wallet: h.indexOf("wallet_balance") > -1 ? h.indexOf("wallet_balance") : 11,
    expiry: h.indexOf("wallet_expiry") > -1 ? h.indexOf("wallet_expiry") : 12,
    lastSent: h.indexOf("last_sent") > -1 ? h.indexOf("last_sent") : -1
  };
}
// ==========================================
// 🛡️ TARGET 1 PATCH: HYBRID BOUNDARY PROTECTOR
// ==========================================
function ensureSystemOverrideColumn(sheet) {
  if (!sheet) return;
  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const hasOverride = headers.some(h => h && h.toString().trim().toLowerCase() === "system_override");
  
  if (!hasOverride) {
    const newCol = sheet.getLastColumn() + 1;
    sheet.getRange(1, newCol).setValue("System_Override");
    Logger.log("✅ SUCCESS: System_Override column safely created at index " + newCol);
  } else {
    Logger.log("✅ SAFE: System_Override column already exists.");
  }
}

function resolveEffectiveStatus(formulaStatus, systemOverride) {
  if (systemOverride && systemOverride.toString().trim() !== "") {
    return systemOverride.toString().trim();
  }
  return formulaStatus ? formulaStatus.toString().trim() : ""; 
}

