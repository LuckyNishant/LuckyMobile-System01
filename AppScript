/**
 * 🧠 MAIN ENGINE: State-Driven Behavior Conditioning
 */
function runStateDrivenEducationEngine() {
  const today = new Date();
  const localToday = new Date(Utilities.formatDate(today, "GMT+5:30", "yyyy-MM-dd") + "T00:00:00+05:30");
  const dayOfWeek = localToday.getDay();
  const hour = today.getHours();

  if (dayOfWeek !== 3 && dayOfWeek !== 0) return; 
  if (hour !== 15) return; 

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const custSheet = ss.getSheetByName("Customers");
  const salesSheet = ss.getSheetByName("Sales");
  if (!custSheet || !salesSheet) return; 

  const custData = custSheet.getDataRange().getValues();
  const salesData = salesSheet.getDataRange().getValues();
  const map = getColMap(custData[0]); 
  
  let educationPushQueue = [];
  
  let shopLastActive = {};
  let thirtyDaysAgo = new Date(localToday);
  thirtyDaysAgo.setDate(localToday.getDate() - 30);

  for (let s = salesData.length - 1; s >= 1; s--) {
    let sDate = new Date(salesData[s][0]);
    let sName = salesData[s][1];
    if (sDate < thirtyDaysAgo) break; 
    if (!shopLastActive[sName]) {
      shopLastActive[sName] = sDate;
    }
  }

  for (let c = 1; c < custData.length; c++) {
    let cId = custData[c][map.id];
    let cName = custData[c][map.name];
    let cPhone = (custData[c][map.phone] || "").toString().replace(/[^0-9]/g, "");
    let cStatus = (custData[c][map.status] || "").toString().toLowerCase();
    let cTier = (custData[c][map.tier] || "Normal").toString().trim();
    let cDue = toNumber(custData[c][map.pending]); 
    
    if (!cId || !cName || cPhone.length < 10) continue; 
    if (cStatus.indexOf("dead") !== -1 || cStatus.indexOf("block") !== -1) continue; 

    let finalPhone = cPhone.length === 10 ? "91" + cPhone : cPhone;
    
    let lastActive = shopLastActive[cName] || null;
    let daysSince = lastActive ? Math.floor((localToday - lastActive) / (1000 * 60 * 60 * 24)) : 999;

    // 🛡️ ECONOMIC DIGNITY GUARDRAIL (The Future-Proof Fix)
    const DIGNITY_FLOOR = 500;

    // 🧠 STATE DETECTION LOGIC
    let retailerState = "NORMAL_ACTIVE";
    if (daysSince > 14) {
        retailerState = "DORMANT";
    } else if (cDue > 8000) {
        retailerState = "HIGH_DUE";
    } else if (cDue < DIGNITY_FLOOR) {
        retailerState = "CLEAN_ACCOUNT"; // 🔒 Locked explicitly to prevent micro-math targeting
    } else if (cTier.indexOf("Premium") !== -1) {
        retailerState = "PREMIUM_ACTIVE";
    }

    let finalMsg = getConditioningMessage(retailerState, cId, cTier);
    educationPushQueue.push({ phone: finalPhone, message: finalMsg });
  }

  safeBatchExecute(educationPushQueue);
  sendStaffComplianceReminder();
}

