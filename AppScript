      amanMsg += "\nकुल बकाया: " + formatMoney(newDue) + "\n\n@Aman: " + (isCashSale ? "यह कैश का काम है, इसलिए होल्ड वाले अकाउंट का माल भी पास कर दिया है।" : "बिल लेजर में चढ़ गया है। जिन पार्टियों का अकाउंट होल्ड पर है, उनका माल बिना पुराना पेमेंट आए बाहर नहीं जाना चाहिए।" );
      if (syncWarning !== "") amanMsg += "\n⚠ अलर्ट: स्टॉक माइनस नहीं हुआ (Sync Error)। फिजिकल स्टॉक चेक कर लेना।";
      
      let lokeshMsg = "💰 *रिकवरी (क्रेडिट) अलर्ट*\nदुकान: " + saleShopInfo.name + "\nकैटेगरी: *" + currentTier + "*\nनया माल गया: " + formatMoney(payableAmount);
      if (isCashSale) {
          lokeshMsg += "\n💵 *मोड: CASH SALE (नकद)*\n*कुल बकाया स्थिर रहा: " + formatMoney(newDue) + "*\n\n@Lokesh: यह माल नकद बिका है, उधारी नहीं बढ़ी।";
      } else {
          lokeshMsg += "\n*कुल बकाया बढ़कर हुआ: " + formatMoney(newDue) + "*\n\n@Lokesh: मार्केट में नई उधारी (क्रेडिट) गई है। अपने फॉलो-अप लिस्ट में नया अमाउंट अपडेट कर लो। Restricted ग्राहकों पर तुरंत फॉलो-अप करो।";
      }

      let pushQueue = [];
      if (saleShopInfo.phone.length >= 10) pushQueue.push({ phone: saleShopInfo.phone, message: receiptMsg });
      pushQueue.push({ phone: STAFF.SATTU, message: sattuMsg });
      pushQueue.push({ phone: STAFF.AMAN, message: amanMsg });
      pushQueue.push({ phone: STAFF.LOKESH, message: lokeshMsg });
      
      pushWebhooksSequential(pushQueue);

      let finalAdminReply = "✅ बिल तैयार - " + saleShopInfo.name + " (" + currentTier + ")\n" + saleLogs.join("\n") + "\n💰 कुल बिल: " + formatMoney(saleGrandTotal);
      if (walletDeducted > 0) finalAdminReply += "\n🛡️ कैशबैक डिस्काउंट: -" + formatMoney(walletDeducted);
      if (isCashSale) finalAdminReply += "\n💵 *CASH SALE (नकद जमा)*";
      finalAdminReply += "\nनया बकाया: " + formatMoney(newDue) + syncWarning + "\n(मैसेज Queue में डाल दिए गए हैं)";
      
      logAudit("INBOUND_SALE", saleShopInfo.name, sender, "Billed: " + formatMoney(saleGrandTotal), "SUCCESS");
      return reply(finalAdminReply);
    }

    // ==========================================
    // 3. PAID COMMAND 
    // ==========================================
    if (command === "PAID") {
      // 🟢 DATE INJECTION LAYER (PAID) START
      let entryDate = new Date();
      let tempParts = [];
      for(let d=0; d<headerParts.length; d++) {
        let tkn = headerParts[d].toUpperCase();
        if(tkn.startsWith("DATE:")) {
           let dp = tkn.substring(5).split("-");
           if(dp.length !== 3) return reply("❌ तिथि फॉर्मेट गलत है। सही: DATE:DD-MM-YYYY");
           let cDate = new Date(parseInt(dp[2], 10), parseInt(dp[1], 10) - 1, parseInt(dp[0], 10), 12, 0, 0);
           if(isNaN(cDate.getTime())) return reply("❌ अमान्य तिथि। सही: DATE:DD-MM-YYYY");
           if(cDate > new Date()) return reply("❌ भविष्य की तिथि मान्य नहीं है।");
           let limit = new Date(); limit.setDate(limit.getDate() - 60);
           if(cDate < limit) return reply("❌ 60 दिन से पुरानी बैकडेट मान्य नहीं है।");
           entryDate = cDate;
        } else { tempParts.push(headerParts[d]); }
      }
      headerParts = tempParts;
      // 🟢 DATE INJECTION LAYER END
      const paidShopId = headerParts[1];
      if (!paidShopId) return reply("⚠ कृपया ID लिखें। उदाहरण: PAID 177 5000");
      const paidShopInfo = getShopInfo(paidShopId, custData, custMap);
      if (!paidShopInfo) return reply("❌ ID नहीं मिली।");
      
      let amtStr = headerParts[2];
      if (!amtStr && lines.length > 1) amtStr = (lines[1].trim().split(/\s+/)[0] || "");
      const payAmount = toNumber(amtStr);
      if (isNaN(payAmount) || payAmount <= 0) return reply("⚠ कृपया सही अमाउंट दर्ज करें। उदाहरण: PAID 177 5000");
      
      const pRow = [new Date(), paidShopInfo.name, "PAYMENT", 0, 0, -payAmount, "OK", 0];
      if (typeof entryDate !== 'undefined') pRow[0] = entryDate; // 🟢 DATE INJECTION
      batchWrite(salesSheet, [pRow]);
      salesData.push(pRow); 
      
      let newDue = paidShopInfo.due - payAmount;
      
      // 👉 REAL-TIME TIER & DUE SYNCHRONIZATION
      let currentTier = calculateDynamicTier(paidShopInfo.name, newDue, paidShopInfo.status, salesData, returnData);
      try { custSheet.getRange(paidShopInfo.rowIndex, custMap.tier + 1).setValue(currentTier); } catch(e) {}
      
      const wtdStats = getWTDStats(paidShopInfo.name, salesData, returnData);
      const fomoMsg = generateFOMOMessage(currentTier, newDue, wtdStats);

      const purchaseTarget = getPurchaseTarget(newDue);
      let purchaseShortfall = Math.max(0, purchaseTarget - wtdStats.netBoughtWTD);
      if (purchaseShortfall < 100) purchaseShortfall = 0;

      const receiptMsg = "✅ *पेमेंट रसीद (लक्की मोबाइल)*\n\nनमस्कार " + paidShopInfo.name + ",\nआपका ₹" + formatMoney(payAmount).replace("₹","").replace("-","") + " का पेमेंट सफलतापूर्वक प्राप्त हो गया है। धन्यवाद!\n\n📊 *अकाउंट समरी:*\n▪ आपकी कैटेगरी: *" + currentTier + "*\n▪ नया बकाया: " + formatMoney(newDue) + "\n▪ इस हफ्ते कुल जमा: " + formatMoney(wtdStats.paidWTD) + "\n" + fomoMsg;

      let lokeshMsg = "💰 *रिकवरी अपडेट*\nदुकान: " + paidShopInfo.name + "\nअभी आया: " + formatMoney(payAmount) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n";
      const creditRequired = getRecoveryTarget(newDue);
      let remainingThisWeek = Math.max(0, creditRequired - wtdStats.paidWTD);
      if (remainingThisWeek < 100 && newDue > 500) remainingThisWeek = 0;
      if (newDue <= 100) remainingThisWeek = 0;

      if (remainingThisWeek > 0) lokeshMsg += "⚠ अभी भी टारगेट (" + formatMoney(remainingThisWeek) + ") बाकी है। फॉलोअप चालू रखो।";
      else lokeshMsg += "✅ वीकली पेमेंट टारगेट पूरा हुआ।";

      let amanMsg = "🛒 *सेल अनलॉक अलर्ट*\nदुकान: " + paidShopInfo.name + "\nअभी आया: " + formatMoney(payAmount) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n";
      if (remainingThisWeek > 0) {
        amanMsg += "🚫 *HOLD ORDER:* इस हफ्ते का पेमेंट टारगेट अभी पूरा नहीं है। नया ऑर्डर होल्ड पर रखो या सिर्फ कैश में निकालो।\n";
      } else {
        amanMsg += "🟢 *SAFE TO ORDER:* पेमेंट टारगेट क्लियर है。\n";
        if (purchaseShortfall > 0) amanMsg += "📉 माल कम खरीदा है (" + formatMoney(purchaseShortfall) + " का शॉर्टफॉल)। कैटलॉग भेजो और ऑर्डर पुश करो।";
        else amanMsg += "📈 खरीदारी टारगेट पर है।";
      }

      const sattuMsg = "📦 *स्टॉक/सिंक इन्फो*\n" + paidShopInfo.name + " का " + formatMoney(payAmount) + " जमा हो गया है। अगर कोई WhatsApp पर रसीद मांगे तो बता देना कि एंट्री हो गई है।";

      let pushQueue = [];
      if (paidShopInfo.phone.length >= 10) pushQueue.push({ phone: paidShopInfo.phone, message: receiptMsg });
      pushQueue.push({ phone: STAFF.LOKESH, message: lokeshMsg });
      pushQueue.push({ phone: STAFF.AMAN, message: amanMsg });
      pushQueue.push({ phone: STAFF.SATTU, message: sattuMsg });
      
      pushWebhooksSequential(pushQueue);

      logAudit("INBOUND_PAID", paidShopInfo.name, sender, "Paid: " + formatMoney(payAmount), "SUCCESS");
      return reply("✅ पेमेंट प्राप्त - " + paidShopInfo.name + " (" + currentTier + ")\n💰 राशि: " + formatMoney(payAmount) + "\nनया बकाया: " + formatMoney(newDue));
    }

    // ==========================================
    // 4. RETURN COMMAND
    // ==========================================
    if (command === "RETURN") {
      const returnShopId = headerParts[1];
      if (!returnShopId) return reply("⚠ कोई रिटर्न आइटम नहीं मिला। उदाहरण: RETURN 177 model qty");
      const returnShopInfo = getShopInfo(returnShopId, custData, custMap);
      if (!returnShopInfo) return reply("❌ ID नहीं मिली।");
      
      let returnItemLines = [];
      if (headerParts.length > 2) returnItemLines.push(headerParts.slice(2));
      for (let r = 1; r < lines.length; r++) {
        let returnParts = lines[r].trim().split(/\s+/);
        if (returnParts.length >= 2) returnItemLines.push(returnParts);
      }
      if (!returnItemLines.length) return reply("⚠ कोई रिटर्न आइटम नहीं मिला। उदाहरण: RETURN 177 model qty");
      
      let returnErrors = [], validReturnItems = [];
      let sattuItemList = ""; 
      let isCustomPriceUsed = false, is100PercentScrap = true; 
      let currentTier = (returnShopInfo.tier || "Normal 🟢").toString().trim();

      for (let ri = 0; ri < returnItemLines.length; ri++) {
        let originalLine = returnItemLines[ri].slice();
        let isScrap = false, customP = -1;
        let lastToken = originalLine[originalLine.length - 1];
        let secondLastToken = originalLine.length >= 2 ? originalLine[originalLine.length - 2] : null;

        if (originalLine.length >= 3 && isNumericToken(lastToken) && isNumericToken(secondLastToken)) {
            customP = toNumber(lastToken);
            if (customP === 0) { isScrap = true; } 
            else { isCustomPriceUsed = true; is100PercentScrap = false; }
        } else { is100PercentScrap = false; }

        let returnItem = parseItem(returnItemLines[ri], currentTier, false, stockMap);
        if (returnItem.error) { returnErrors.push(returnItem.error); continue; }

        let totalBought = 0, totalReturned = 0;
        let rModelClean = normalizeKey(returnItem.model);
        for (let s = salesData.length - 1; s >= 1; s--) {
          if (salesData[s][1] === returnShopInfo.name && salesData[s][2] !== "PAYMENT" && normalizeKey(salesData[s][2]) === rModelClean) totalBought += toNumber(salesData[s][3]);
        }
        for (let rr_idx = returnData.length - 1; rr_idx >= 1; rr_idx--) {
          if (returnData[rr_idx][1] === returnShopInfo.name && normalizeKey(returnData[rr_idx][2]) === rModelClean) totalReturned += toNumber(returnData[rr_idx][3]);
        }

        let eligibleQty = totalBought - totalReturned;
        if (returnItem.qty > eligibleQty) {
          returnErrors.push(returnItem.model + " (कुल खरीदा: " + totalBought + ", पहले वापस किया: " + totalReturned + ", एलिजिबल बैलेंस: " + eligibleQty + ")");
          continue;
        }

        let refundVal = isScrap ? 0 : (customP !== -1 ? returnItem.qty * customP : returnItem.total);
        returnItem.refundVal = refundVal;
        returnItem.isScrap = isScrap;

        if (!returnItem.isSpecial && !isScrap) {
            stockMap[normalizeKey(returnItem.model)].stock += returnItem.qty;
            returnItem.finalStock = stockMap[normalizeKey(returnItem.model)].stock;
            if (customP !== -1 && customP !== returnItem.price) {
                let oldTotalValue = returnItem.stock * returnItem.price; 
                let returnedItemValue = returnItem.qty * customP; 
                returnItem.newAvgPrice = (oldTotalValue + returnedItemValue) / returnItem.finalStock;
            }
        }
        validReturnItems.push(returnItem);
        sattuItemList += "🔸 " + returnItem.model + " | Qty: " + returnItem.qty + (isScrap ? " 🔴 [SCRAP-BIN]" : " 🟢 [RACK-ADDED]") + "\n";
      }
      
      if (returnErrors.length > 0) return reply("❌ RETURN REJECTED ❌\nनीचे दिए गए मॉडल में दिक्कत है:\n" + returnErrors.join("\n"));

      let returnRowsToSave = [], totalReturnVal = 0, stockUpdates = [];
      for (let k = 0; k < validReturnItems.length; k++) {
        let vi = validReturnItems[k];
        let writePrice = (vi.refundVal === 0) ? 0 : (vi.refundVal / vi.qty);
        let rRow = [new Date(), returnShopInfo.name, vi.model, vi.qty, writePrice, vi.total, vi.refundVal, -vi.profit];
        returnRowsToSave.push(rRow);
        returnData.push(rRow); 
        totalReturnVal += vi.refundVal;

        if (!vi.isSpecial && !vi.isScrap && vi.rowIndex) {
            let updateObj = { row: vi.rowIndex, finalStock: vi.finalStock, model: vi.model };
            if (vi.newAvgPrice) updateObj.newAvgPrice = vi.newAvgPrice;
            stockUpdates.push(updateObj);
        }
      }

      batchWrite(returnSheet, returnRowsToSave);

      for (let u = 0; u < stockUpdates.length; u++) {
        try {
          liveStockSheet.getRange(stockUpdates[u].row, 2).setValue(stockUpdates[u].finalStock);
          if (stockUpdates[u].newAvgPrice) liveStockSheet.getRange(stockUpdates[u].row, 3).setValue(stockUpdates[u].newAvgPrice);
        } catch (err) {}
      }

      let lifetimePurchase = 0, lifetimeReturn = totalReturnVal;
      for (let rp = salesData.length - 1; rp >= 1; rp--) {
        if (salesData[rp][1] === returnShopInfo.name && salesData[rp][2] !== "PAYMENT") lifetimePurchase += toNumber(salesData[rp][5]);
      }
      for (let rr2 = returnData.length - 1; rr2 >= 1; rr2--) {
        if (returnData[rr2][1] === returnShopInfo.name) {
          let retVal2 = (returnData[rr2][6] !== "" && returnData[rr2][6] !== undefined) ? toNumber(returnData[rr2][6]) : toNumber(returnData[rr2][5]);
          lifetimeReturn += retVal2;
        }
      }
      
      let isHighReturn = (lifetimePurchase > 0 && lifetimeReturn > (lifetimePurchase * 0.30));
      let newDue = returnShopInfo.due - totalReturnVal;

      // 👉 REAL-TIME TIER & DUE SYNCHRONIZATION
      currentTier = calculateDynamicTier(returnShopInfo.name, newDue, returnShopInfo.status, salesData, returnData);
      try { custSheet.getRange(returnShopInfo.rowIndex, custMap.tier + 1).setValue(currentTier); } catch(e) {}

      let pushQueue = [];
      if (!is100PercentScrap) {
          let receiptMsg = "✅ *रिटर्न रसीद (लक्की मोबाइल)*\n\nनमस्कार " + returnShopInfo.name + ",\nआपका माल वापस जमा कर लिया गया है।\n\n";
          if (isCustomPriceUsed) {
              receiptMsg += "सूचना: आपके द्वारा वापस किया गया माल खाते में एडजस्ट कर दिया गया है। विवरण के लिए लोकेश से संपर्क करें।\n";
          } else {
              receiptMsg += "📊 *अकाउंट समरी:*\n▪ रिटर्न अमाउंट: " + formatMoney(totalReturnVal) + "\n▪ पुराना बकाया: " + formatMoney(returnShopInfo.due) + "\n▪ *नया बकाया: " + formatMoney(newDue) + "*\n";
          }
          if (isHighReturn) receiptMsg += "\n⚠️ **ज़्यादा रिटर्न का अपडेट**\n\nभाई, आपका रिटर्न का माल आपकी टोटल सेल के 30% से ऊपर जा रहा है। मार्केट में इतना माल वापस आता है तो रोटेशन टूटता है और नुकसान दोनों तरफ होता है।\n\n👉 कस्टमर से पुराना माल लेते टाइम थोड़ा ध्यान से चेक कर लिया करो।\n👉 जो माल रनिंग हो, बस वही मंगाया करो।\n\nकाम एकदम सॉलिड रखो ताकि दोनों का पैसा न अटके।";
          
          if (returnShopInfo.phone.length >= 10) pushQueue.push({ phone: returnShopInfo.phone, message: receiptMsg });
      }
      
      let sattuMsg = "📦 *स्टॉक रिटर्न अलर्ट*\nदुकान: " + returnShopInfo.name + "\n\n*वापस आया माल:*\n" + sattuItemList + "\n@Sattu: 🟢 RACK वाले माल को सिस्टम में प्लस कर दिया गया है, फिजिकल रैक में रखो। 🔴 SCRAP वाले माल को अलग डिब्बे में डालो।";
      let amanMsg = "🛒 *सेल्स/रिटर्न अलर्ट*\nदुकान: " + returnShopInfo.name + "\nरिटर्न अमाउंट: " + formatMoney(totalReturnVal) + "\n\n";
      if (is100PercentScrap) amanMsg += "⚠️ ध्यान दें: यह माल पूरी तरह खराब (SCRAP) में आया है। वारंटी या डिफेक्ट चेक करो।\n";
      if (isHighReturn) amanMsg += "🚫 *HIGH RETURN WARNING:* इस ग्राहक का रिटर्न 30 प्रतिशत पार कर गया है। इसे बिना वजह एक्स्ट्रा माल बिल्कुल मत भेजना, नुकसान हो रहा है।";
      else amanMsg += "🟢 रिटर्न नॉर्मल लिमिट में है।";
      let lokeshMsg = "💰 *रिकवरी (रिटर्न) अलर्ट*\nदुकान: " + returnShopInfo.name + "\nक्रेडिट नोट वैल्यू: " + formatMoney(totalReturnVal) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n@Lokesh: यह माल वापस आया है, कैश नहीं। वीकली 20 प्रतिशत टारगेट के लिए इस वैल्यू को मत गिनना।";
      
      pushQueue.push({ phone: STAFF.SATTU, message: sattuMsg });
      pushQueue.push({ phone: STAFF.AMAN, message: amanMsg });
      pushQueue.push({ phone: STAFF.LOKESH, message: lokeshMsg });
      
      pushWebhooksSequential(pushQueue);

      logAudit("INBOUND_RETURN", returnShopInfo.name, sender, "Return: " + formatMoney(totalReturnVal), "SUCCESS");
      let finalReply = "✅ रिटर्न दर्ज: " + returnShopInfo.name + "\n💰 अमाउंट: " + formatMoney(totalReturnVal);
      if (isHighReturn) finalReply += "\n⚠ हाई रिटर्न अलर्ट: 30 प्रतिशत क्रॉस हो गया है।";
      return reply(finalReply);
    }

    // ==========================================
    // 4.5 CANCEL COMMAND
    // ==========================================
    if (command === "CANCEL") {
      // 🟢 DATE INJECTION LAYER (CANCEL) START
      let entryDate = new Date();
      let tempParts = [];
      let isBackdated = false;
      for(let d=0; d<headerParts.length; d++) {
        let tkn = headerParts[d].toUpperCase();
        if(tkn.startsWith("DATE:")) {
           let dp = tkn.substring(5).split("-");
           if(dp.length !== 3) return reply("❌ तिथि फॉर्मेट गलत है। सही: DATE:DD-MM-YYYY");
           let cDate = new Date(parseInt(dp[2], 10), parseInt(dp[1], 10) - 1, parseInt(dp[0], 10), 12, 0, 0);
           if(isNaN(cDate.getTime())) return reply("❌ अमान्य तिथि। सही: DATE:DD-MM-YYYY");
           if(cDate > new Date()) return reply("❌ भविष्य की तिथि मान्य नहीं है।");
           let limit = new Date(); limit.setDate(limit.getDate() - 60);
           if(cDate < limit) return reply("❌ 60 दिन से पुरानी बैकडेट मान्य नहीं है।");
           entryDate = cDate;
           isBackdated = true;
        } else { tempParts.push(headerParts[d]); }
      }
      headerParts = tempParts;
      // 🟢 DATE INJECTION LAYER END
      const cancelShopId = headerParts[1];
      if (!cancelShopId) return reply("⚠ कोई आइटम नहीं मिला। उदाहरण: CANCEL 177 Y20 2");
      const cancelShopInfo = getShopInfo(cancelShopId, custData, custMap);
      if (!cancelShopInfo) return reply("❌ ID नहीं मिली।");
      let currentTier = (cancelShopInfo.tier || "Normal 🟢").toString().trim();
      
      let cancelItemLines = [];
      if (headerParts.length > 2) cancelItemLines.push(headerParts.slice(2));
      for (let c = 1; c < lines.length; c++) {
        let cancelParts = lines[c].trim().split(/\s+/);
        if (cancelParts.length >= 2) cancelItemLines.push(cancelParts);
      }
      if (!cancelItemLines.length) return reply("⚠ कोई आइटम नहीं मिला। उदाहरण: CANCEL 177 Y20 2");
      
      let cancelErrors = [], validCancelItems = [];
      // 🟢 DATE INJECTION: Temporary constructor hijack
      let OriginalDate = Date;
      if (typeof isBackdated !== 'undefined' && isBackdated) {
        Date = function(...args) { 
          if (args.length === 0) return new OriginalDate(entryDate.getTime());
          return new OriginalDate(...args);
        };
        Date.prototype = OriginalDate.prototype; Date.now = OriginalDate.now; Date.parse = OriginalDate.parse; Date.UTC = OriginalDate.UTC;
      }
      const todayStr = Utilities.formatDate(new Date(), tz, "yyyy-MM-dd");
      const todayStart = new Date(todayStr + "T00:00:00+05:30");
      if (typeof isBackdated !== 'undefined' && isBackdated) { Date = OriginalDate; } // 🟢 DATE INJECTION RESTORE

      for (let ci = 0; ci < cancelItemLines.length; ci++) {
        let cItem = parseItem(cancelItemLines[ci], currentTier, false, stockMap);
        if (cItem.error) { cancelErrors.push(cItem.error); continue; }
        
        let totalSoldToday = 0, totalCancelledToday = 0;
        let cModelClean = normalizeKey(cItem.model);

        for (let s = salesData.length - 1; s >= 1; s--) {
          if (!salesData[s][0]) continue;
          if (new Date(salesData[s][0]) < todayStart) break; 
          
          if (salesData[s][1] === cancelShopInfo.name) {
            let rowItemName = (salesData[s][2] || "").toString();
            if (rowItemName !== "PAYMENT" && rowItemName.indexOf("[CANCEL]") === -1 && normalizeKey(rowItemName) === cModelClean) {
              totalSoldToday += toNumber(salesData[s][3]);
            } else if (rowItemName.indexOf("❌ [CANCEL]") !== -1) {
              let cleanRowName = normalizeKey(rowItemName.replace("❌ [CANCEL]", "").trim());
              if (cleanRowName === cModelClean) totalCancelledToday += Math.abs(toNumber(salesData[s][3]));
            }
          }
        }

        let eligibleCancelQty = totalSoldToday - totalCancelledToday;
        if (cItem.qty > eligibleCancelQty) {
          cancelErrors.push(cItem.model + " (फ्रॉड लॉक: आज इस शॉप को सिर्फ " + eligibleCancelQty + " पीस बिके हैं।)");
          continue;
        }

        if (!cItem.isSpecial) {
          stockMap[normalizeKey(cItem.model)].stock += cItem.qty; 
          cItem.finalStock = stockMap[normalizeKey(cItem.model)].stock;
        }
        validCancelItems.push(cItem);
      }
      
      if (cancelErrors.length > 0) return reply("❌ CANCEL REJECTED ❌\n" + cancelErrors.join("\n"));

      let cancelRowsToSave = [], cancelLogs = [], cancelGrandTotal = 0, stockUpdates = [];

      for (let k = 0; k < validCancelItems.length; k++) {
        let vi = validCancelItems[k];
        let cRow = [new Date(), cancelShopInfo.name, "❌ [CANCEL] " + vi.model, -vi.qty, vi.price, -vi.total, "CANCELLED", -vi.profit];
        if (typeof entryDate !== 'undefined') cRow[0] = entryDate; // 🟢 DATE INJECTION
        cancelRowsToSave.push(cRow);
        salesData.push(cRow); 
        cancelGrandTotal += vi.total;
        cancelLogs.push("रद्द: " + vi.model + " x " + vi.qty);
        if (!vi.isSpecial && vi.rowIndex) stockUpdates.push({ row: vi.rowIndex, finalStock: vi.finalStock, model: vi.model });
      }

      batchWrite(salesSheet, cancelRowsToSave);

      for (let u = 0; u < stockUpdates.length; u++) {
        try { liveStockSheet.getRange(stockUpdates[u].row, 2).setValue(stockUpdates[u].finalStock); } 
        catch (err) {}
      }

      let newDue = cancelShopInfo.due - cancelGrandTotal;

      // 👉 REAL-TIME TIER & DUE SYNCHRONIZATION
      currentTier = calculateDynamicTier(cancelShopInfo.name, newDue, cancelShopInfo.status, salesData, returnData);
      try { custSheet.getRange(cancelShopInfo.rowIndex, custMap.tier + 1).setValue(currentTier); } catch(e) {}

      let cancelReceiptMsg = "❌ *ऑर्डर रद्द (लक्की मोबाइल)*\n\nनमस्कार " + cancelShopInfo.name + ",\nआपका निम्नलिखित माल बिल से हटा (रद्द) दिया गया है:\n" + cancelLogs.join("\n") + "\n\n📊 *अकाउंट समरी:*\n▪ रद्द किया गया अमाउंट: " + formatMoney(cancelGrandTotal) + "\n▪ *नया बकाया: " + formatMoney(newDue) + "*\n\nधन्यवाद।";

      let pushQueue = [];
      if (cancelShopInfo.phone.length >= 10) pushQueue.push({ phone: cancelShopInfo.phone, message: cancelReceiptMsg });
      
      pushQueue.push({ phone: STAFF.SATTU, message: "🛑 *ऑर्डर कैंसिल अलर्ट*\nदुकान: " + cancelShopInfo.name + "\n*कैंसिल माल:*\n" + cancelLogs.join("\n") + "\n\n@Sattu: यह माल कैंसिल हो गया है, इसे डिस्पैच मत करना। वापस रैक में रख दो।" });
      pushQueue.push({ phone: STAFF.AMAN, message: "🛒 *सेल रद्द (CANCEL)*\nदुकान: " + cancelShopInfo.name + "\nकैंसिल अमाउंट: " + formatMoney(cancelGrandTotal) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n@Aman: यह बिल सिस्टम से हटा दिया गया है। अपने टारगेट में से इसे माइनस कर लो।" });
      pushQueue.push({ phone: STAFF.LOKESH, message: "💰 *रिकवरी (कैंसिल) अलर्ट*\nदुकान: " + cancelShopInfo.name + "\nकैंसिल वैल्यू: " + formatMoney(cancelGrandTotal) + "\n*कुल बकाया वापस घटकर हुआ: " + formatMoney(newDue) + "*\n\n@Lokesh: यह बिल कैंसिल हुआ है। अपनी रिकवरी लिस्ट में नया अमाउंट अपडेट कर लो।" });
      
      pushWebhooksSequential(pushQueue);

      logAudit("INBOUND_CANCEL", cancelShopInfo.name, sender, "Cancel: " + formatMoney(cancelGrandTotal), "SUCCESS");
      return reply("✅ सेल रद्द (CANCEL) - " + cancelShopInfo.name + "\n" + cancelLogs.join("\n") + "\n📉 रिवर्स अमाउंट: " + formatMoney(cancelGrandTotal) + "\nनया बकाया: " + formatMoney(newDue));
    }
    
    // ==========================================
    // 4.6 CANCEL RETURN COMMAND (HARDENED REVERSAL)
    // ==========================================
    if (command === "CANCELRETURN") {
      var crShopId = headerParts[1];
      if (!crShopId) return reply("⚠ कृपया ID लिखें। उदाहरण: CANCELRETURN 177 VIVOY20 2");
      var crShopInfo = getShopInfo(crShopId, custData, custMap);
      if (!crShopInfo) return reply("❌ ID नहीं मिली।");

      var crParts = [];
      if (headerParts.length > 2) {
          crParts = headerParts.slice(2);
      } else if (lines.length > 1) {
          crParts = lines[1].trim().split(/\s+/);
      }
      if (crParts.length < 2) return reply("⚠ कृपया मॉडल और Qty लिखें। उदाहरण: CANCELRETURN 177 Y20 2");
      
      // 🚨 FIX: Handle trailing price. If last two tokens are numbers, drop the last one (price).
      var lastVal = toNumber(crParts[crParts.length - 1]);
      var secondLastVal = crParts.length > 1 ? toNumber(crParts[crParts.length - 2]) : NaN;
      if (!isNaN(lastVal) && !isNaN(secondLastVal)) {
          crParts.pop(); // Drop the price
      }
      
      var crQty = toNumber(crParts.pop());
      var crModelRaw = crParts.join(" ");
      var crModelClean = normalizeKey(crModelRaw);

      if (crQty <= 0) return reply("⚠ Qty सही नहीं है।");

      var matchStock = stockMap[crModelClean];
      if (!matchStock) return reply("❌ '" + crModelRaw + "' इन्वेंट्री में नहीं मिला।");

      // 1. LIFO Exact Match Lookup in Return Ledger
      var targetReturn = null;
      var thirtyDaysLimit = getStartDateDaysAgo(30);

      for (var r = returnData.length - 1; r >= 1; r--) {
          if (!returnData[r][0]) continue;
          var rDate = new Date(returnData[r][0]);
          if (rDate < thirtyDaysLimit) break;

          var rShop = returnData[r][1];
          var rModel = (returnData[r][2] || "").toString();
          var rQtyLedger = toNumber(returnData[r][3]);

          // 🚨 FIX: Compare sheet model with Canonical matchStock.name, NOT the raw input alias
          if (rShop === crShopInfo.name && normalizeKey(rModel) === normalizeKey(matchStock.name) && rQtyLedger === crQty) {
              var rNote = (returnData[r][8] || "").toString() + " " + (returnData[r][2] || "").toString();
              if (rNote.indexOf("CRET_") !== -1 || rNote.indexOf("[CANCEL]") !== -1) continue; 
              
              targetReturn = {
                  rowIndex: r + 1,
                  timestamp: rDate.getTime(),
                  dateObj: rDate,
                  model: rModel,
                  qty: rQtyLedger,
                  price: toNumber(returnData[r][4]),
                  total: toNumber(returnData[r][5]),
                  refundVal: (returnData[r][6] !== "" && returnData[r][6] !== undefined) ? toNumber(returnData[r][6]) : toNumber(returnData[r][5]),
                  profit: toNumber(returnData[r][7]) || 0
              };
              break;
          }
      }

      if (!targetReturn) {
          return reply("❌ पिछले 30 दिनों में " + crShopInfo.name + " का " + matchStock.name + " (" + crQty + " पीस) का कोई रिटर्न रिकॉर्ड नहीं मिला। (Qty एकदम सटीक होनी चाहिए)");
      }

      // 2. Immutable Fingerprint Generation
      var cleanShopName = (crShopInfo.name || "").toString().replace(/\s+/g, '').toUpperCase();
      var fingerprint = "CRET_" + targetReturn.timestamp + "_" + cleanShopName + "_" + crModelClean + "_" + crQty;

      // 3. Duplicate Reversal Scan
      var isDuplicate = false;
      for (var dr = returnData.length - 1; dr >= 1; dr--) {
          var rowRef = (returnData[dr][8] || "").toString();
          if (rowRef.indexOf(fingerprint) !== -1) {
              isDuplicate = true;
              break;
          }
      }

      if (isDuplicate) {
          try { logAudit("INBOUND_CANCELRETURN", crShopInfo.name, sender, "Double Reversal Blocked", "REJECTED"); } catch(e){}
          return reply("❌ REVERSAL BLOCKED: यह रिटर्न पहले ही रिवर्स किया जा चुका है।\n🔑 Fingerprint: " + fingerprint);
      }

      // 4. Stock Safety Check
      var wasScrap = (targetReturn.refundVal === 0);
      var currentStock = matchStock.stock;
      
      if (!wasScrap && !matchStock.universal) {
          if (currentStock < crQty) {
              return reply("❌ STOCK LOCK: रैक में वर्तमान स्टॉक (" + currentStock + ") रिवर्सल Qty (" + crQty + ") से कम है। स्टॉक नेगेटिव में नहीं जा सकता।");
          }
      }

      // 5. Cache Service Execution Lock
      var liveCache = CacheService.getScriptCache();
      var liveCancelLockKey = "LOCK_LIVEREV_" + fingerprint;
      
      if (liveCache.get(liveCancelLockKey)) {
          console.warn("REPLAY DETECTED: Dropping execution for " + fingerprint);
          return reply("⚠️ REPLAY DETECTED: Execution already in progress. Request dropped.");
      }
      liveCache.put(liveCancelLockKey, "LOCKED", 600);

      // 6. RAM Calculations
      var newStock = currentStock;
      if (!wasScrap) newStock -= crQty;

      var newDue = crShopInfo.due + targetReturn.refundVal;
      var newTier = crShopInfo.tier; 

      try {
          // 7. MUTATION ZONE
          // Commit 1: Ledger Append [Date, Shop, Model, Qty, Price, Total, RefundVal, Profit, Fingerprint]
          var crRow = [new Date(), crShopInfo.name, "❌ [CANCEL] RETURN " + matchStock.name, -targetReturn.qty, targetReturn.price, -targetReturn.total, -targetReturn.refundVal, -targetReturn.profit, fingerprint];
          batchWrite(returnSheet, [crRow]);
          returnData.push(crRow); 

          // Commit 2: Stock Deduct
          if (!wasScrap) {
              liveStockSheet.getRange(matchStock.rowIndex, 2).setValue(newStock);
          }

          // Commit 3: Pending Due
          //custSheet.getRange(crShopInfo.rowIndex, custMap.pending + 1).setValue(newDue);\\

          // Commit 4: Tier Sync
          newTier = calculateDynamicTier(crShopInfo.name, newDue, crShopInfo.status, salesData, returnData);
          custSheet.getRange(crShopInfo.rowIndex, custMap.tier + 1).setValue(newTier);

          // 8. Audit & WhatsApp Push
          try { logAudit("INBOUND_CANCELRETURN", crShopInfo.name, sender, "Reversed Return: " + matchStock.name, "SUCCESS"); } catch(e){}

          var formattedDate = Utilities.formatDate(targetReturn.dateObj, "GMT+05:30", "dd-MMM-yyyy HH:mm");
          
          var msg = "✅ *रिटर्न रिवर्सल सफल (CANCEL RETURN)* ✅\n" +
                    "कमांड: @CANCELRETURN\n\n" +
                    "📅 टारगेट रिटर्न: " + formattedDate + "\n" +
                    "🔑 Fingerprint: `" + fingerprint + "`\n\n" +
                    "📦 *स्टॉक इम्पैक्ट:*\n" +
                    "▪ मॉडल: " + matchStock.name + "\n" +
                    "▪ हटाई गई Qty: " + (wasScrap ? "0 (Scrap था)" : crQty) + "\n" +
                    "▪ नया रैक स्टॉक: " + newStock + "\n\n" +
                    "📊 *अकाउंट समरी (" + crShopInfo.name + "):*\n" +
                    "▪ रिवर्स अमाउंट: +" + formatMoney(targetReturn.refundVal) + "\n" +
                    "▪ *नया कुल बकाया:* " + formatMoney(newDue) + "\n" +
                    "▪ अपडेटेड टियर: *" + newTier + "*";

          var sattuMsg = "🛑 *रिटर्न कैंसिल अलर्ट*\nदुकान: " + crShopInfo.name + "\nमॉडल: " + matchStock.name + "\nQty: " + crQty + "\n\n@Sattu: यह रिटर्न गलती से चढ़ा था, अब हटा दिया गया है। " + (wasScrap ? "यह माल स्क्रैप में था, उसे वहीँ रहने दो।" : "रैक से " + crQty + " पीस वापस निकाल लो।");
          var lokeshMsg = "🛑 *रिटर्न रिवर्सल (क्रेडिट वापस बढ़ा)*\nदुकान: " + crShopInfo.name + "\nरद्द रिटर्न अमाउंट: +" + formatMoney(targetReturn.refundVal) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n@Lokesh: यह रिटर्न हटा दिया गया है, बकाया वापस बढ़ा दिया गया है।";

          var pushQueue = [];
          if (crShopInfo.phone.length >= 10) pushQueue.push({ phone: crShopInfo.phone, message: msg });
          pushQueue.push({ phone: STAFF.SATTU, message: sattuMsg });
          pushQueue.push({ phone: STAFF.LOKESH, message: lokeshMsg });
          
          pushWebhooksSequential(pushQueue);

          return reply("✅ रिटर्न रद्द (CANCEL RETURN) - " + crShopInfo.name + "\n📦 स्टॉक एडजस्टेड: " + newStock + "\n💰 रिवर्स अमाउंट: +" + formatMoney(targetReturn.refundVal) + "\nनया बकाया: " + formatMoney(newDue) + "\n🔑 " + fingerprint);

      } catch (e) {
          liveCache.remove(liveCancelLockKey); 
          try { logAudit("SYSTEM_ERROR", "CANCELRETURN", sender, e.message, "FAILED"); } catch(ex){}
          return reply("🛑 *CRITICAL FAILURE IN REVERSAL*\nCause: " + e.message + "\n⚠️ लेज़र राइटिंग फेल हो गई है। कृपया Sync_Error_Log चेक करें।");
      }
    }

    // ==========================================
    // 3.5 CANCEL PAYMENT COMMAND (HARDENED REVERSAL)
    // ==========================================
    if (command === "CANCELPAY") {
      var cPayShopId = headerParts[1];
      if (!cPayShopId) return reply("⚠ कृपया ID लिखें। उदाहरण: CANCELPAY 177 1200");
      var cPayShopInfo = getShopInfo(cPayShopId, custData, custMap);
      if (!cPayShopInfo) return reply("❌ ID नहीं मिली।");

      var cPayAmtStr = headerParts[2];
      if (!cPayAmtStr && lines.length > 1) cPayAmtStr = (lines[1].trim().split(/\s+/)[0] || "");
      var cPayAmount = toNumber(cPayAmtStr);
      
      if (isNaN(cPayAmount) || cPayAmount <= 0) return reply("⚠ कृपया सही अमाउंट दर्ज करें। उदाहरण: CANCELPAY 177 1200");

      var targetPayment = null;
      var thirtyDaysLimit = getStartDateDaysAgo(30);

      // 1. LIFO Exact Match Lookup
      for (var sp = salesData.length - 1; sp >= 1; sp--) {
        if (!salesData[sp][0]) continue;
        var spDate = new Date(salesData[sp][0]);
        if (spDate < thirtyDaysLimit) break; 

        if (salesData[sp][1] === cPayShopInfo.name && salesData[sp][2] === "PAYMENT") {
            var recordedAmt = toNumber(salesData[sp][5]); // Negative in ledger
            if (Math.abs(recordedAmt) === cPayAmount) {
                targetPayment = {
                    timestamp: spDate.getTime(),
                    dateObj: spDate,
                    amount: Math.abs(recordedAmt)
                };
                break; // Grabs the most recent exact match
            }
        }
      }

      if (!targetPayment) {
          return reply("❌ पिछले 30 दिनों में " + cPayShopInfo.name + " का " + formatMoney(cPayAmount) + " का कोई पेमेंट रिकॉर्ड नहीं मिला।\n(अमाउंट एकदम सटीक होना चाहिए)");
      }

      // 2. Immutable Payment Fingerprint Generation
      var cleanShopName = (cPayShopInfo.name || "").toString().replace(/\s+/g, '').toUpperCase();
      var fingerprint = "PAY_" + targetPayment.timestamp + "_" + cleanShopName + "_" + targetPayment.amount;

      // 3. Duplicate Reversal Scan
      var isDuplicate = false;
      for (var dr = salesData.length - 1; dr >= 1; dr--) {
        var rowRef = (salesData[dr][7] || "").toString() + " " + (salesData[dr][2] || "").toString();
        if (rowRef.indexOf(fingerprint) !== -1) {
            isDuplicate = true;
            break;
        }
      }
      
      if (isDuplicate) {
          try { logAudit("INBOUND_CANCELPAY", cPayShopInfo.name, sender, "Double Reversal Blocked", "REJECTED"); } catch(e){}
          return reply("❌ REVERSAL BLOCKED: यह पेमेंट पहले ही रिवर्स किया जा चुका है।\n🔑 Fingerprint: " + fingerprint);
      }

      // 4. Cache Service Execution Lock
      var liveCache = CacheService.getScriptCache();
      var liveCancelLockKey = "LOCK_LIVEREV_" + fingerprint;
      
      if (liveCache.get(liveCancelLockKey)) {
          console.warn("REPLAY DETECTED: Dropping execution for " + fingerprint);
          return reply("⚠️ REPLAY DETECTED: Execution already in progress. Request dropped.");
      }
      liveCache.put(liveCancelLockKey, "LOCKED", 600);

      var newDue = cPayShopInfo.due + cPayAmount;
      var newTier = cPayShopInfo.tier; 

      try {
          // 5. MUTATION 1: Ledger Commit
          var cpRow = [new Date(), cPayShopInfo.name, "❌ [CANCEL] PAYMENT", 0, 0, Math.abs(cPayAmount), "REVERSAL", fingerprint];
          batchWrite(salesSheet, [cpRow]);
          salesData.push(cpRow); 

          // 6. MUTATION 2: Pending Due
          //custSheet.getRange(cPayShopInfo.rowIndex, custMap.pending + 1).setValue(newDue);\\

          // 7. MUTATION 3: Post-Commit Tier Sync
          newTier = calculateDynamicTier(cPayShopInfo.name, newDue, cPayShopInfo.status, salesData, returnData);
          custSheet.getRange(cPayShopInfo.rowIndex, custMap.tier + 1).setValue(newTier);

          // 8. Audit & WhatsApp Push
          try { logAudit("INBOUND_CANCELPAY", cPayShopInfo.name, sender, "Reversed: " + formatMoney(cPayAmount), "SUCCESS"); } catch(e){}

          var formattedDate = Utilities.formatDate(targetPayment.dateObj, "GMT+05:30", "dd-MMM-yyyy HH:mm");
          
          var cPayMsg = "✅ *पेमेंट रद्द (REVERSAL)*\n\nनमस्कार " + cPayShopInfo.name + ",\nआपका " + formattedDate + " को दर्ज हुआ " + formatMoney(cPayAmount) + " का पेमेंट सिस्टम से हटा दिया गया है।\n\n📊 *अकाउंट समरी:*\n▪ आपकी कैटेगरी: *" + newTier + "*\n▪ यह अमाउंट वापस आपके बकाये में जोड़ दिया गया है।\n▪ *नया कुल बकाया: " + formatMoney(newDue) + "*\n(सटीक नया बकाया चेक करने के लिए HISTORY कमांड का उपयोग करें)";

          var lokeshMsg = "🛑 *पेमेंट रिवर्सल अलर्ट*\nदुकान: " + cPayShopInfo.name + "\nरद्द अमाउंट: +" + formatMoney(cPayAmount) + "\nनया बकाया: " + formatMoney(newDue) + "\n\n@Lokesh: यह पेमेंट सिस्टम से रिवर्स हो गया है। रिकवरी लिस्ट में इस अमाउंट को वापस Due में जोड़ लें।";

          var pushQueue = [];
          if (cPayShopInfo.phone.length >= 10) pushQueue.push({ phone: cPayShopInfo.phone, message: cPayMsg });
          pushQueue.push({ phone: STAFF.LOKESH, message: lokeshMsg });
          pushWebhooksSequential(pushQueue);

          return reply("✅ पेमेंट रद्द (REVERSAL) - " + cPayShopInfo.name + "\n💰 रिवर्स अमाउंट: +" + formatMoney(cPayAmount) + "\nनया बकाया: " + formatMoney(newDue) + "\n🔑 " + fingerprint);

      } catch (e) {
          liveCache.remove(liveCancelLockKey); 
          try { logAudit("SYSTEM_ERROR", "CANCELPAY", sender, e.message, "FAILED"); } catch(ex){}
          return reply("🛑 *CRITICAL FAILURE IN REVERSAL*\nCause: " + e.message + "\n⚠️ लेज़र राइटिंग फेल हो गई है। कृपया Sync_Error_Log चेक करें।");
      }
    }

    // ==========================================
    // 11.5 CANCEL STOCKUP COMMAND (SAFE REVERSAL)
    // ==========================================
    if (command === "CANCELSTOCKUP") {
      var cStockupLines = [];
      if (headerParts.length > 1) cStockupLines.push(headerParts.slice(1));
      for (var cs = 1; cs < lines.length; cs++) {
        var cParts = lines[cs].trim().split(/\s+/);
        if (cParts.length >= 2) cStockupLines.push(cParts);
      }

      if (!cStockupLines.length) return reply("⚠ कोई आइटम नहीं मिला। फॉर्मेट:\n@CANCELSTOCKUP\nModel Qty Price(SP)");

      var safeRawDumpSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Raw_dump");
      if (!safeRawDumpSheet) return reply("❌ 'Raw_dump' शीट नहीं मिली। रिवर्सल वेरिफिकेशन असंभव है।");
      
      var rawData = safeRawDumpSheet.getDataRange().getValues();

     var snapSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Stockup_Snapshots");
      var snapData = snapSheet ? snapSheet.getDataRange().getValues() : [];

     var walletMapSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Stockup_Wallet_Map");
      var walletMapData = walletMapSheet ? walletMapSheet.getDataRange().getValues() : [];

      var custSheetLocal = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Customers");
      var custDataLocal = custSheetLocal ? custSheetLocal.getDataRange().getValues() : [];
      var nameColIdx = -1, walletColIdx = -1;
      if (custDataLocal.length > 0) {
          for (var c = 0; c < custDataLocal[0].length; c++) {
              var hdr = custDataLocal[0][c].toString().toLowerCase().trim();
              if (hdr === "id" || hdr.indexOf("shop") !== -1 || hdr.indexOf("name") !== -1) {
                  if (nameColIdx === -1) nameColIdx = c; 
              }
              // STRICT MATCH: Target only "wallet_balance" to prevent hijacking by expiry columns
              if (hdr === "wallet_balance") {
                  walletColIdx = c;
              }
          }
          // Failsafe Fallback if exact match fails
          if (walletColIdx === -1) {
              for (var c = 0; c < custDataLocal[0].length; c++) {
                  var backupHdr = custDataLocal[0][c].toString().toLowerCase();
                  if (backupHdr.indexOf("wallet") !== -1 && backupHdr.indexOf("expiry") === -1) {
                      walletColIdx = c;
                      break;
                  }
              }
          }
      }

      var cStockupErrors = [];
      var validCancelStockups = [];
      var thirtyDaysAgo = getStartDateDaysAgo(30);

      for (var csi = 0; csi < cStockupLines.length; csi++) {
        var csparts = cStockupLines[csi].slice();
        if (csparts.length < 3) {
           cStockupErrors.push("❌ " + csparts.join(" ") + " (फॉर्मेट गलत है)");
           continue;
        }

        var cpIn = toNumber(csparts.pop()); 
        var cqIn = toNumber(csparts.pop()); 
        var cmIn = csparts.join(" ");       

        var matchStock = stockMap[normalizeKey(cmIn)];
        if (!matchStock) {
           cStockupErrors.push("❌ " + cmIn + " (मॉडल नहीं मिला)");
           continue;
        }

        // Exact Match Verification in Raw_dump
        var entryFound = false;
        for (var rd = rawData.length - 1; rd >= 1; rd--) {
            if (!rawData[rd][0]) continue;
            var rdDate = new Date(rawData[rd][0]);
            if (rdDate < thirtyDaysAgo) break;

            var rdModel = normalizeKey(rawData[rd][1]);
            var rdQty = toNumber(rawData[rd][2]);
            var rdPrice = toNumber(rawData[rd][3]);
            var rdNote = (rawData[rd][4] || "").toString();

            if (rdModel === normalizeKey(matchStock.name) && rdQty === cqIn && rdPrice === cpIn && rdNote.indexOf("STOCKUP") !== -1 && rdNote.indexOf("REVERSAL") === -1) {
                entryFound = true;
                break;
            }
        }

        if (!entryFound) {
            cStockupErrors.push("❌ " + matchStock.name + " (Raw_dump में " + cqIn + " पीस @ " + cpIn + " की कोई ओरिजिनल एंट्री नहीं मिली)");
            continue;
        }

       // ==========================================
        // MICRO-STEP 2.1: EVENTID LOOKUP & SNAPSHOT DETECTION
        // ==========================================
        var snapFound = false;
        var targetEventID = "";
        var snap_BaseSP = 0, snap_SilverSP = 0, snap_PremiumSP = 0, snap_GoldSP = 0, snap_CP = 0;
        var associatedWalletRows = [];

        for (var sn = snapData.length - 1; sn >= 1; sn--) {
            var snModel = normalizeKey(snapData[sn][2]);
            var snQtyIn = toNumber(snapData[sn][3]);
            var snPriceIn = toNumber(snapData[sn][4]);
            
            // 3-Factor Exact Match: Model + Qty + Price
            if (snModel === normalizeKey(matchStock.name) && snQtyIn === cqIn && snPriceIn === cpIn) {
                var snDate = new Date(snapData[sn][0]);
                if (snDate >= thirtyDaysAgo) {
                    targetEventID = (snapData[sn][1] || "").toString();
                    var targetEventDate = snDate; // Track for post-event lock
                    
                    // New Snapshot Column Mapping (Col 6 is Old_BaseSP)
                    snap_BaseSP = toNumber(snapData[sn][6]);
                    snap_SilverSP = toNumber(snapData[sn][7]);
                    snap_PremiumSP = toNumber(snapData[sn][8]);
                    snap_GoldSP = toNumber(snapData[sn][9]);
                    snap_CP = toNumber(snapData[sn][10]);
                    snapFound = true;
                    break; // Specific exact stockup event found
                }
            }
        }

       if (!snapFound) {
            cStockupErrors.push("❌ " + matchStock.name + " (Exact Event Snapshot नहीं मिला। यह स्टॉकअप सेफली रिवर्स नहीं हो सकता।)");
            continue;
        }

        // ==========================================
        // POST-EVENT MUTATION LOCK (REFINED)
        // ==========================================
        var newerMutationFound = false;
        for (var rd = 1; rd < rawData.length; rd++) {
            if (!rawData[rd][0]) continue;
            var rdDate = new Date(rawData[rd][0]);
            var rdModel = normalizeKey(rawData[rd][1]);
            
            // Allow 2 seconds buffer for same-batch execution latency
            if (rdModel === normalizeKey(matchStock.name) && (rdDate.getTime() - targetEventDate.getTime()) > 2000) {
                var rdNote = (rawData[rd][4] || "").toString().toUpperCase();
                
                // Block ONLY if the later row is a real economic mutation
                if (rdNote.indexOf("SALE") !== -1 || 
                    rdNote.indexOf("RETURN") !== -1 || 
                    rdNote.indexOf("STOCKUP") !== -1 || 
                    rdNote.indexOf("CANCEL") !== -1 || 
                    rdNote.indexOf("PURCHASE") !== -1) {
                    
                    newerMutationFound = true;
                    break;
                }
            }
        }

        if (newerMutationFound) {
            cStockupErrors.push("❌ " + matchStock.name + "\n(Unsafe historical rollback detected. This model has newer transactional mutations after the target STOCKUP. Replay engine required.)");
            continue;
        }

       // ==========================================
        // WALLET REVERSAL EXTRACTION (Negative Allowed)
        // ==========================================
        if (targetEventID !== "") {
            for (var wr = 1; wr < walletMapData.length; wr++) {
                var wEventID = (walletMapData[wr][1] || "").toString();
                if (wEventID === targetEventID) {
                    var wShop = walletMapData[wr][2];
                    var wRefund = toNumber(walletMapData[wr][3]);
                    associatedWalletRows.push({ shopName: wShop, refundAmt: wRefund });
                }
            }
        }

        var currentQty = matchStock.stock;
        
        // Qty subtracts (preserves new sales), Economics restore exactly
        var newPhysicalQty = currentQty - cqIn;

        validCancelStockups.push({
           model: matchStock.name, 
           cancelQty: cqIn, 
           cancelPrice: cpIn, 
           newQty: newPhysicalQty,
           newAvgSP: snap_BaseSP,
           newSilverSP: snap_SilverSP,
           newPremiumSP: snap_PremiumSP,
           newGoldSP: snap_GoldSP,
           newAvgCP: snap_CP,
           rowIndex: matchStock.rowIndex,
           eventID: targetEventID,
           walletReversals: associatedWalletRows
        });
      }

      if (cStockupErrors.length > 0) {
          return reply("❌ CANCEL STOCKUP REJECTED ❌\n" + cStockupErrors.join("\n"));
      }

     var reversalDumpRows = [], reversalLogs = [], walletDeductLogs = [], syncErrors = [];

      for (var ck = 0; ck < validCancelStockups.length; ck++) {
          var vcs = validCancelStockups[ck];
          reversalDumpRows.push([new Date(), vcs.model, -vcs.cancelQty, vcs.cancelPrice, "❌ STOCKUP REVERSAL (Event: " + (vcs.eventID || "N/A") + ")"]);
          reversalLogs.push("👉 " + vcs.model + " | हटाई गई Qty: " + vcs.cancelQty + " | नया रैक स्टॉक: " + vcs.newQty);

          // 1. LIVE STOCK WRITEBACK (Price Restores)
          try {
              liveStockSheet.getRange(vcs.rowIndex, 2).setValue(vcs.newQty);       // B: Qty
              liveStockSheet.getRange(vcs.rowIndex, 3).setValue(vcs.newAvgSP);     // C: Base SP
              liveStockSheet.getRange(vcs.rowIndex, 7).setValue(vcs.newAvgCP);     // G: Actual CP
              liveStockSheet.getRange(vcs.rowIndex, 8).setValue(vcs.newPremiumSP); // H: Cash
              liveStockSheet.getRange(vcs.rowIndex, 9).setValue(vcs.newSilverSP);  // I: Silver
              liveStockSheet.getRange(vcs.rowIndex, 10).setValue(vcs.newGoldSP);   // J: Gold
              liveStockSheet.getRange(vcs.rowIndex, 11).setValue(vcs.newPremiumSP);// K: Premium
          } catch (err) { syncErrors.push([new Date(), "CANCELSTOCKUP", vcs.model, vcs.cancelQty, err.toString()]); }

          // 2. WALLET REVERSAL WRITEBACK (Negative Additive Mutation)
          if (vcs.walletReversals && vcs.walletReversals.length > 0 && custSheetLocal && nameColIdx !== -1 && walletColIdx !== -1) {
              for (var w = 0; w < vcs.walletReversals.length; w++) {
                  var wRev = vcs.walletReversals[w];
                  var targetRow = -1;
                  var currentWalletBal = 0;
                  
                  for (var r = 1; r < custDataLocal.length; r++) {
                      if (normalizeKey(custDataLocal[r][nameColIdx]) === normalizeKey(wRev.shopName)) {
                          targetRow = r + 1; // 1-based API index
                          currentWalletBal = toNumber(custDataLocal[r][walletColIdx]);
                          break;
                      }
                  }

                  if (targetRow !== -1) {
                      var newWalletBal = currentWalletBal - wRev.refundAmt;

                      try {
                          custSheetLocal.getRange(targetRow, walletColIdx + 1).setValue(newWalletBal);
                          walletDeductLogs.push("💳 " + wRev.shopName + " (-" + formatMoney(wRev.refundAmt) + " Reverted)");
                      } catch(err) { syncErrors.push([new Date(), "WALLET_REVERSE", wRev.shopName, wRev.refundAmt, err.toString()]); }
                  }
              }
          }
      }

      if (reversalDumpRows.length > 0) {
          try { batchWrite(safeRawDumpSheet, reversalDumpRows); } catch(e) {}
      }

      if (syncErrors.length > 0) {
          try {
              var errorSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Sync_Error_Log");
              if (!errorSheet) errorSheet = SpreadsheetApp.getActiveSpreadsheet().insertSheet("Sync_Error_Log");
              batchWrite(errorSheet, syncErrors);
          } catch(e) {}
          return reply("⚠ रिवर्सल के दौरान एरर आए। सिंक लॉग चेक करें।\n\n" + reversalLogs.join("\n"));
      }

      logAudit("INBOUND_CANCELSTOCKUP", "SYSTEM", sender, "Reversed Stockup & Wallets", "SUCCESS");
      
      var finalStockReversalMsg = "✅ *स्टॉकअप रद्द (FULL ECONOMIC REVERSAL)*\n\n" + reversalLogs.join("\n");
      if (walletDeductLogs.length > 0) {
          finalStockReversalMsg += "\n\n⚠️ *वॉलेट रिकवरी (Cashback Reversed)* ⚠️\n" + walletDeductLogs.join("\n");
      }
      return reply(finalStockReversalMsg);
    }
    // ==========================================
    // 4.6 EXP COMMAND
    // ==========================================
    if (command === "EXP") {
      var cat = headerParts[1] || "General";
      var amt = toNumber(headerParts[2] || (lines.length > 1 ? lines[1] : 0));
      var note = lines.length > 1 ? lines.slice(1).join(" ") : "";
      
      if (amt <= 0) return reply("⚠ खर्चा दर्ज करने के लिए सही अमाउंट लिखें।");
      
      var expSheet = ss.getSheetByName("Expenses Sheet") || ss.getSheetByName("Expenses");
      if (!expSheet) {
        expSheet = ss.insertSheet("Expenses Sheet");
        batchWrite(expSheet, [["Date", "Category", "Amount", "Note"]]);
      }
      
      batchWrite(expSheet, [[new Date(), cat, amt, note]]);
      logAudit("INBOUND_EXP", "SYSTEM", sender, "Exp: " + formatMoney(amt), "SUCCESS");
      return reply("✅ खर्चा दर्ज: " + cat + "\n💰 राशि: " + formatMoney(amt));
    }

    // ==========================================
    // 5. HISTORY COMMAND
    // ==========================================
    if (command === "HISTORY") {
      var historyShopId = headerParts[1];
      if (!historyShopId) return reply("⚠ कृपया ID लिखें। उदाहरण: HISTORY 177");
      var historyShopInfo = getShopInfo(historyShopId, custData, custMap);
      if (!historyShopInfo) return reply("❌ ID नहीं मिली।");
      
      var thirtyDaysAgo = getStartDateDaysAgo(30);
      var weeklyPayment = 0;
      var startOfWk = getStartDateDaysAgo(new Date().getDay() || 7 - 1); // Exact start of week

      var historyEntries = [];
      
      for (var hs = salesData.length - 1; hs >= 1; hs--) {
        if (!salesData[hs][0]) continue;
        var salesRowDate = new Date(salesData[hs][0]);
        if (salesRowDate < thirtyDaysAgo) break; 

        if (salesData[hs][1] === historyShopInfo.name) {
            var salesLabel = salesData[hs][2] === "PAYMENT" ? "✅ Payment - " + formatMoney(Math.abs(toNumber(salesData[hs][5]))) : "🛒 " + salesData[hs][2] + " - " + formatMoney(toNumber(salesData[hs][5]));
            historyEntries.push({ time: salesRowDate.getTime(), text: Utilities.formatDate(salesRowDate, tz, "dd/MM") + " : " + salesLabel });
            
            if (salesData[hs][2] === "PAYMENT" && salesRowDate >= startOfWk) {
                weeklyPayment += Math.abs(toNumber(salesData[hs][5]));
            }
        }
      }
      
      for (var hr = returnData.length - 1; hr >= 1; hr--) {
        if (!returnData[hr][0]) continue;
        var returnRowDate = new Date(returnData[hr][0]);
        if (returnRowDate < thirtyDaysAgo) break;

        if (returnData[hr][1] === historyShopInfo.name) {
            var actualRet = (returnData[hr][6] !== "" && returnData[hr][6] !== undefined) ? toNumber(returnData[hr][6]) : toNumber(returnData[hr][5]);
            historyEntries.push({ time: returnRowDate.getTime(), text: Utilities.formatDate(returnRowDate, tz, "dd/MM") + " : 🔄 रिटर्न " + returnData[hr][2] + " - " + formatMoney(actualRet) });
        }
      }
      
      historyEntries.sort(function (a, b) { return a.time - b.time; });
      var historyMsg = "";
      
      if (historyEntries.length === 0) {
        historyMsg = "❌ " + historyShopInfo.name + "\nपिछले 30 दिन में कोई लेनदेन नहीं मिला।";
      } else {
        var trimmedHistory = historyEntries.slice(-15).map(function (x) { return x.text; });
        historyMsg = "📜 हिस्ट्री (Last 30 Days) - " + historyShopInfo.name + "\n" + trimmedHistory.join("\n");
      }
      
      historyMsg += "\n💰 कुल बकाया: " + formatMoney(historyShopInfo.due);
      var reqPayment = getRecoveryTarget(historyShopInfo.due);
      
      if (historyShopInfo.due > 100 && weeklyPayment < reqPayment) {
        historyMsg += "\n@Lokesh: पिछले हफ्ते " + historyShopInfo.name + " से " + (weeklyPayment === 0 ? "कोई पेमेंट नहीं" : "केवल " + formatMoney(weeklyPayment)) + " आया है।\n🎯 रिकवरी का टारगेट फेल है ❌\n⚡ आज ही कॉल लगाओ या सीधा दुकान पर जाकर मिलकर आओ। कैशफ्लो रोटेट करवाओ।";
      }
      
      logAudit("INBOUND_HISTORY", historyShopInfo.name, sender, "Checked History", "SUCCESS");
      return reply(historyMsg);
    }
    
    // ==========================================
    // 13.5 RECOVERY COMMAND
    // ==========================================
    if (command === "RECOVERY" || command === "ALLDUE") {
      var ninetyDaysAgo = getStartDateDaysAgo(90);
      var recoveryList = [];
      var totalMarketDue = 0;
      
      for (var c = 1; c < custData.length; c++) {
        var cId = custData[c][custMap.id];
        var cName = custData[c][custMap.name];
        if (!cId || !cName) continue;
        
        var cDue = toNumber(custData[c][custMap.pending]);
        var cStatus = (custData[c][custMap.status] || "").toString().toLowerCase();
        var payment90 = 0;
        
        for (var s = salesData.length - 1; s >= 1; s--) {
          if (!salesData[s][0]) continue;
          var pDate = new Date(salesData[s][0]);
          if (pDate < ninetyDaysAgo) break; 

          if (salesData[s][1] === cName && salesData[s][2] === "PAYMENT") {
              payment90 += Math.abs(toNumber(salesData[s][5]));
          }
        }
        
        totalMarketDue += cDue;
        var score = 999; 
        var emoji = "⚪"; 
        
        if (cDue > 0) {
          score = payment90 / cDue;
          if (cStatus.indexOf("block") !== -1 || payment90 === 0) {
            emoji = "⚫"; score = -1;
          } else if (score < 0.20) { emoji = "🔴";
          } else if (score < 0.80) { emoji = "🔵";
          } else { emoji = "🟢"; }
        } else if (payment90 > 0) emoji = "🟢";
        else { emoji = "⚪"; score = 1000; }
        
        recoveryList.push({ id: cId, name: cName, due: cDue, paid: payment90, score: score, emoji: emoji });
      }
      
      recoveryList.sort(function(a, b) { return a.score - b.score; });
      var recoveryMsg = ["🎯 *मार्केट रिकवरी रिपोर्ट (Last 90 Days)* 🎯\n"];
      
      for (var r = 0; r < recoveryList.length; r++) {
        var item = recoveryList[r];
        if (item.emoji === "⚪") continue; 
        recoveryMsg.push(item.emoji + " " + item.name + " | Due: " + formatMoney(item.due) + " | Paid: " + formatMoney(item.paid));
      }
      
      recoveryMsg.push("\n------------------");
      recoveryMsg.push("💰 *मार्केट में फंसा कुल पैसा:* " + formatMoney(totalMarketDue));
      recoveryMsg.push("\n@Lokesh: ⚫ और 🔴 वाले खातों पर आज ही एक्शन लो। मार्केट में पैसा जाम हो रहा है।");
      
      logAudit("INBOUND_RECOVERY", "SYSTEM", sender, "Generated Recovery List", "SUCCESS");
      return reply(recoveryMsg.join("\n"));
    }

    // ==========================================
    // 6. CREDIT COMMAND (BUSINESS HARDENED)
    // ==========================================
    if (command === "CREDIT") {
      var creditShopId = headerParts[1];
      if (!creditShopId) return reply("⚠ कृपया ID लिखें। उदाहरण: CREDIT 177");
      var creditShopInfo = getShopInfo(creditShopId, custData, custMap);
      if (!creditShopInfo) return reply("❌ ID नहीं मिली।");
      
      var creditWeeklyPayment = getWeeklyPaymentForShop(creditShopInfo.name, salesData, 7);
      var creditRequired = getRecoveryTarget(creditShopInfo.due);
      
      var creditRemaining = creditRequired - creditWeeklyPayment;
      if (creditRemaining < 100 && creditShopInfo.due > 500) creditRemaining = 0; 
      if (creditShopInfo.due <= 500 && creditRemaining < 0) creditRemaining = 0;
      if (creditShopInfo.due <= 100) creditRemaining = 0;
      
      if (creditShopInfo.due <= 100 || creditRemaining <= 0) {
        var creditOkMsg = "✅ **लेजर अपडेट**\n\n" +
                          "भैया " + creditShopInfo.name + ",\n" +
                          "इस हफ्ते का अपना पेमेंट रोटेशन एकदम बराबर आ गया है।\n\n" +
                          "आपका काम बढ़िया है, इसलिए आगे से आपके अकाउंट में क्रेडिट (उधारी) की लिमिट थोड़ी और खोल दी है। अब आगे बिना टेंशन माल की क्वांटिटी बढ़ा सकते हो।\n\n" +
                          "👉 नए स्टॉक और रेट के लिए अमन से बात कर लेना।\n\n" +
                          "🛠 **@Aman:**\n" +
                          "भैया को नए स्टॉक के फोटो और डाउन रेट WhatsApp करो। इनका रोटेशन एकदम क्लियर है, इनको अपने 'प्रीमियम' काउंटर में सेट रखो और नया माल दिखाओ।";
        logAudit("INBOUND_CREDIT", creditShopInfo.name, sender, "Credit OK sent", "SUCCESS");
        return reply(creditOkMsg);
      }
      
      var creditMsg = "⚠️ **अकाउंट अपडेट**\n\n" +
                "भाई " + creditShopInfo.name + ",\n" +
                "पिछले 7 दिन में अपना पेमेंट थोड़ा धीमा रहा है। मार्केट में माल की चाल बनी रहे, इसके लिए टोटल बैलेंस का " + (creditShopInfo.due > 500 ? "कम से कम 20%" : "पूरा अमाउंट") + " रेगुलर आना चाहिए।\n\n" +
                "💸 **टोटल बैलेंस:** " + formatMoney(creditShopInfo.due) + "\n" +
                "📥 **इस हफ्ते आया:** " + formatMoney(creditWeeklyPayment) + "\n" +
                "🎯 **आज का पेंडिंग टारगेट:** " + formatMoney(creditRemaining) + "\n\n" +
                "पैसा एक जगह रुकता है तो पीछे से नया स्टॉक मंगाने में दिक्कत आती है और सबका माल लेट होता है।\n\n" +
                "आज टाइम निकाल कर ये पेंडिंग अमाउंट फ्री करवा दो। एक बार लोकेश से बात करके अपना हिसाब क्लियर कर लेना, ताकि आगे आपका और दूसरों का नया माल बिना रुके निकलता रहे।";
logAudit("INBOUND_CREDIT", creditShopInfo.name, sender, "Credit Demand: " + formatMoney(creditRemaining), "SUCCESS");
return reply(creditMsg);
    }

