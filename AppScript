function logAudit(event, shop, phone, details, status) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName("System_Audit_Log");
    if (!sheet) {
      sheet = ss.insertSheet("System_Audit_Log");
      sheet.appendRow(["Timestamp", "Event", "Shop", "Phone", "Details", "Status"]);
    }
    sheet.appendRow([new Date(), event, shop, phone, details, status]);
  } catch(e) { Logger.log("Audit Log Fail: " + e.message); }
}

function updateBusinessDashboard(custData) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName("Business_Dashboard");
    if (!sheet) {
      sheet = ss.insertSheet("Business_Dashboard");
      sheet.appendRow(["Date", "Total Premium", "Total Normal", "Total Blocked", "Total Market Due"]);
    }
    
    const map = getColMap(custData[0]);
    let premium = 0, normal = 0, blocked = 0, totalDue = 0;

    for(let i = 1; i < custData.length; i++) {
      let tier = (custData[i][map.tier] || "").toString().toUpperCase();
      let status = (custData[i][map.status] || "").toString().toUpperCase();
      let due = Number(custData[i][map.pending]) || 0;

      if (status.includes("BLOCK") || status.includes("DEAD") || status.includes("LEGAL")) blocked++;
      else if (tier.includes("PREMIUM")) premium++;
      else normal++;

      totalDue += due;
    }
    sheet.appendRow([new Date(), premium, normal, blocked, totalDue]);
  } catch(e) {}
}


