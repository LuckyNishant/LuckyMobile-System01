              if (!salesData[sd][0]) continue;
              var sDate = new Date(salesData[sd][0]);
              if (sDate < thirtyDaysAgo) break; 
              
              var sItemName = (salesData[sd][2] || "").toString();
              
              if (sItemName !== "PAYMENT" && sItemName.indexOf("[CANCEL]") === -1 && normalizeKey(sItemName) === cModelClean) {
                  var sShopName = salesData[sd][1] || "";
                  var shopDetails = shopInfoByName[sShopName];

                  // Track highest market anchor price (STRICTLY EXCLUDING RETAIL)
                  // Prevents retail margins from artificially inflating wholesale Base Price
                  if (sShopName.toString().toLowerCase().indexOf("retailshop") === -1 && sShopName.toString().indexOf("154") === -1) {
                      var sPrice = toNumber(salesData[sd][4]); 
                      if (sPrice > last30DaysHighestPrice) last30DaysHighestPrice = sPrice;
                  }
                  
                 // FIX: Price drop shield triggers ONLY if inbound rate drops below the actual premium floor, not the inflated base price
                  if (pIn < oldPremium && shopDetails && shopDetails.tier.toUpperCase().indexOf("PREMIUM GOLD") !== -1) {
                      var sQty = Math.abs(toNumber(salesData[sd][3]));
                      var daysPassed = Math.floor((todayTime - sDate.getTime()) / 86400000);
                      if (daysPassed < 0) daysPassed = 0;

                      // Exposure Math: MIN(purchasedQty, 30) - daysPassed
                      var eligibleProtectionDays = Math.min(sQty, 30) - daysPassed;
                      
                      if (eligibleProtectionDays > 0) {
                          if (!eligibleBuyers[sShopName]) eligibleBuyers[sShopName] = { info: shopDetails, qty: 0 };
                          eligibleBuyers[sShopName].qty += eligibleProtectionDays;
                          totalEligibleProtectedQty += eligibleProtectionDays;
                      }
                  }
              }
          }

          // Anchor Fallback
          if (last30DaysHighestPrice === 0) last30DaysHighestPrice = Math.max(oldSP, pIn);

          var finalLiveSP = 0;
          var totalRefundCost = 0;

          // FIX: Evaluate price crash using true baseline floor
          if (pIn < oldPremium && totalEligibleProtectedQty > 0) {
              var baseQtyForMath = Math.max(0, oldQty);
              var virtualTotalValue = (baseQtyForMath * oldSP) + (totalEligibleProtectedQty * oldSP) + (qIn * pIn);
              var virtualTotalQty = baseQtyForMath + totalEligibleProtectedQty + qIn;
              var virtualAvgSP = virtualTotalValue / virtualTotalQty;

              var dropPerPiece = oldSP - virtualAvgSP;
              var refundPerPiece = dropPerPiece * 0.50; 

              totalRefundCost = totalEligibleProtectedQty * refundPerPiece;

              for (var shopKey in eligibleBuyers) {
                  var buyer = eligibleBuyers[shopKey];
                  var refundAmt = buyer.qty * refundPerPiece;
                  
                  // Capture individual wallet mutation tied to EventID
                  walletMapRows.push([new Date(), eventID, shopKey, refundAmt]);
                  
                  var rIdx = buyer.info.rowIndex;
                  if(!walletUpdates[rIdx]) {
                      walletUpdates[rIdx] = { 
                          shopName: shopKey, 
                          newWallet: buyer.info.wallet, 
                          walletCol: buyer.info.walletColIndex, 
                          expiryCol: buyer.info.expiryColIndex,
                          refundAdded: 0
                      };
                  }
                  walletUpdates[rIdx].newWallet += refundAmt;
                  walletUpdates[rIdx].refundAdded += refundAmt;
              }
          }

          // ==========================================
          // MICRO-STEP 2: PREMIUM / CASH ECONOMIC FLOOR
          // ==========================================
          var protectionAdjustedAvg = 0;

          if (physicalQty <= 0) {
              protectionAdjustedAvg = pIn;
          } else {
              if (oldQty <= 0) {
                  // Handles negative stock mathematically correctly
                  protectionAdjustedAvg = ((physicalQty * pIn) + totalRefundCost) / physicalQty;
              } else {
                  // FIX: Blend using oldPremium to calculate true cost-reflective floor, NOT oldSP
                  protectionAdjustedAvg = ((oldQty * oldPremium) + (qIn * pIn) + totalRefundCost) / physicalQty;
              }
          }

          // COMPATIBILITY BRIDGE: Feed isolated floor into legacy variable to prevent writeback crash
          finalLiveSP = protectionAdjustedAvg;

          var finalLiveCP = finalLiveSP / 1.1; 

          // ==========================================
          // MICRO-STEP 3: BASE PRICE GENERATION (MEMORY ONLY)
          // ==========================================
          var crashSeverity = 0;
          if (oldSP > 0 && pIn < oldSP) {
              crashSeverity = (oldSP - pIn) / oldSP;
              if (crashSeverity > 1) crashSeverity = 1; // Failsafe
          }

          var historicalSpread = last30DaysHighestPrice - protectionAdjustedAvg;
          if (historicalSpread < 0) historicalSpread = 0;

          // Spread aggressively compresses if market crashes
          var compressedSpread = historicalSpread * (1 - crashSeverity);
          
          var memoryBasePrice = protectionAdjustedAvg + compressedSpread;

          // Sanity Cap: Never exceed historical anchor
          if (memoryBasePrice > last30DaysHighestPrice && last30DaysHighestPrice > protectionAdjustedAvg) {
              memoryBasePrice = last30DaysHighestPrice;
          }

          // ==========================================
          // MICRO-STEP 4: SILVER PRICE GENERATION (MEMORY ONLY)
          // ==========================================
          var walletDistributedPerPc = physicalQty > 0 ? (totalRefundCost / physicalQty) : 0;
          
          // Recovery: Base और Premium के बीच के गैप का 30% हिस्सा रिकवरी मार्जिन के रूप में।
          // यह मार्केट क्रैश होने पर खुद ही छोटा (Compress) हो जाएगा।
          var controlledRecoveryMargin = (memoryBasePrice - protectionAdjustedAvg) * 0.30;
          
          var memorySilverPrice = protectionAdjustedAvg + walletDistributedPerPc + controlledRecoveryMargin;

          // Mathematical Failsafes: Silver हमेशा Premium से ज्यादा और Base से कम होना चाहिए।
          if (memorySilverPrice < protectionAdjustedAvg) memorySilverPrice = protectionAdjustedAvg;
          if (memorySilverPrice > memoryBasePrice) memorySilverPrice = memoryBasePrice;

          // ==========================================
          // FULL ECONOMIC EVENT SNAPSHOT CAPTURE
          // ==========================================
          snapshotRows.push([
              new Date(), eventID, matchStock.name, qIn, pIn, // Core Event
              preQty, preBaseSP, preSilverSP, prePremiumSP, preGoldSP, preCP, // Pre-State
              physicalQty, roundMarketPrice(memoryBasePrice), roundMarketPrice(memorySilverPrice), roundMarketPrice(protectionAdjustedAvg), roundMarketPrice(protectionAdjustedAvg), finalLiveCP, // Post-State
              totalRefundCost, walletDistributedPerPc, protectionAdjustedAvg, last30DaysHighestPrice // Economics
          ]);

          validStockupItems.push({
             model: matchStock.name, qtyIn: qIn, priceIn: pIn, newQty: physicalQty,
             newAvgCP: finalLiveCP, 
             baseSP: roundMarketPrice(memoryBasePrice),
             silverSP: roundMarketPrice(memorySilverPrice),
             premiumSP: roundMarketPrice(protectionAdjustedAvg),
             rowIndex: matchStock.rowIndex,
             refundDistributed: totalRefundCost
          });
        }

        if (stockupErrors.length > 0) {
            cache.remove(stockupLockKey);
            logAudit("INBOUND_STOCKUP", "SYSTEM", sender, "Rejected with errors", "REJECTED");
            return reply("❌ STOCKUP REJECTED ❌\nनीचे दिए गए मॉडल में दिक्कत है:\n" + stockupErrors.join("\n"));
        }

        var rawDumpRows = [], stockupLogs = [], syncErrors = [];
        var totalShieldMoney = 0;

        // WRITE PHASE 1: LIVE STOCK
        for (var k = 0; k < validStockupItems.length; k++) {
          var vi = validStockupItems[k];
          var dumpNote = vi.refundDistributed > 0 ? "STOCKUP (Shield Active: " + formatMoney(vi.refundDistributed) + ")" : "STOCKUP (Auto Bulk)";
          rawDumpRows.push([new Date(), vi.model, vi.qtyIn, vi.priceIn, dumpNote]);
          
         var logLine = "👉 " + vi.model + " | Qty: " + vi.newQty + " | Premium Rate: " + formatMoney(vi.premiumSP);
          if (vi.refundDistributed > 0) {
              logLine += "\n   🛡️ एक्सपोज़र प्राइस ड्रॉप बाँटा गया: " + formatMoney(vi.refundDistributed);
