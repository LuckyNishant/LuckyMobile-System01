function outbound_EOD() {
  const today = new Date();
  const hour = today.getHours();
  if (hour !== 22) return; 

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const salesData = ss.getSheetByName("Sales").getDataRange().getValues();
  const returnData = ss.getSheetByName("Return").getDataRange().getValues();
  const custData = ss.getSheetByName("Customers").getDataRange().getValues();
  
  let todayStr = Utilities.formatDate(today, "GMT+5:30", "yyyy-MM-dd");
  let todayMid = new Date(todayStr + "T00:00:00+05:30");
  
  let todaySales = 0, todayPayment = 0, todayReturn = 0, todayGrossProfit = 0, variableExp = 0;
  
  for (let es = salesData.length - 1; es >= 1; es--) {
    if (!salesData[es][0]) continue;
    if (new Date(salesData[es][0]) < todayMid) break;

    if (salesData[es][2] === "PAYMENT") {
      todayPayment += Math.abs(toNumber(salesData[es][5]));
    } else {
      let sVal = toNumber(salesData[es][5]);
      todaySales += sVal;
      let pVal = (salesData[es][7] !== "" && salesData[es][7] !== undefined) ? toNumber(salesData[es][7]) : 0;
      todayGrossProfit += pVal;
    }
  }

  for (let er = returnData.length - 1; er >= 1; er--) {
    if (!returnData[er][0]) continue;
    if (new Date(returnData[er][0]) < todayMid) break;

    let actualRet = (returnData[er][6] !== "" && returnData[er][6] !== undefined) ? toNumber(returnData[er][6]) : toNumber(returnData[er][5]); 
    todayReturn += actualRet;
    let rpVal = (returnData[er][7] !== "" && returnData[er][7] !== undefined) ? toNumber(returnData[er][7]) : 0;
    todayGrossProfit += rpVal; 
  }

  let expSheet = ss.getSheetByName("Expenses") || ss.getSheetByName("Expenses Sheet");
  if (expSheet) {
      let expData = expSheet.getDataRange().getValues();
      for(let ex = expData.length - 1; ex >= 1; ex--){
          if (!expData[ex][0]) continue;
          if (new Date(expData[ex][0]) < todayMid) break;
          variableExp += toNumber(expData[ex][2] || expData[ex][1]); 
      }
  }

  let netTodaySales = Math.max(0, todaySales - todayReturn);
  let netProfit = todayGrossProfit - DAILY_FIXED_EXPENSE - variableExp;
  
  // Update the business dashboard (Observability)
  updateBusinessDashboard(custData);
  
  let netProfitStr = netProfit >= 0 ? "➕ " + formatMoney(netProfit) + " (Profit ✅)" : "🔴 " + formatMoney(netProfit) + " (Loss)";
  
  let eodMsg = "📊 *दिनांत रिपोर्ट (EOD) लक्की मोबाइल*\n📅 तारीख: " + Utilities.formatDate(today, "GMT+5:30", "dd/MM/yyyy") + "\n\n";
  eodMsg += "📈 आज की कुल सेल: " + formatMoney(todaySales) + "\n📉 आज का रिटर्न: " + formatMoney(todayReturn) + "\n✅ नेट सेल: " + formatMoney(netTodaySales) + "\n💰 आज का कलेक्शन: " + formatMoney(todayPayment) + "\n\n";
  eodMsg += "💡 *प्रॉफिट & लॉस (P&L):*\n";
  eodMsg += "➕ ग्रॉस प्रॉफिट: " + formatMoney(todayGrossProfit) + "\n";
  eodMsg += "➖ फिक्स खर्च: " + formatMoney(DAILY_FIXED_EXPENSE) + "\n";
  if (variableExp > 0) eodMsg += "➖ अन्य खर्च: " + formatMoney(variableExp) + "\n";
  eodMsg += "🎯 *आज का नेट कैश: " + netProfitStr + "*\n\n";

  if (netTodaySales > 0 && todayPayment < (netTodaySales * 0.5)) {
    eodMsg += "⚠ *कैशफ्लो वार्निंग:* सेल का 50 प्रतिशत कैश भी वापस नहीं आया है। मार्केट में पैसा फंसा है। कल सुबह रिकवरी पर जोर दो।";
  } else if (netTodaySales > 0 && todayPayment >= netTodaySales) {
    eodMsg += "🟢 *कैशफ्लो पॉजिटिव:* रोटेशन परफेक्ट है।";
  }
  
  pushToMacroDroid(STAFF.ADMIN, eodMsg); 
  logAudit("OUTBOUND_EOD", "SYSTEM", "ALL", "Generated Auto EOD", "SUCCESS");
}

