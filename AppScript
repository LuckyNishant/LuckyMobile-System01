      let netBuy7 = Math.max(0, stats.buy_7 - stats.ret_7);
      let netBuy14 = Math.max(0, stats.buy_14 - stats.ret_14);
      let netBuy21 = Math.max(0, stats.buy_21 - stats.ret_21);

