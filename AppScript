}

function parseItem(arr, tier, isCashSale, localStockMap) {
  let stockMap = localStockMap;
  let parts = (arr || []).slice();
  let q = 1, p = 0, m = "";
  if (parts.length === 0) return { error: "❌ खाली लाइन मिली।" };
  
  if (parts[0].toString().charAt(0) === '@') {
    if (parts.length >= 3 && isNumericToken(parts[parts.length - 1]) && isNumericToken(parts[parts.length - 2])) {
      p = toNumber(parts.pop()); q = toNumber(parts.pop());
    } else if (parts.length >= 2 && isNumericToken(parts[parts.length - 1])) { p = toNumber(parts.pop()); }
    m = parts.join(" ");
    if (p <= 0) return { error: "❌ " + m + " (बाहरी आइटम का रेट लिखना जरूरी है)" };
    
    p = roundMarketPrice(p);
    let totalC = q * p;
    let estCP = totalC / 1.1; 
    return { model: "[Special] " + m.substring(1).trim(), qty: q, price: p, total: totalC, profit: totalC - estCP, isSpecial: true };
  }
  
  let lastIsNum = isNumericToken(parts[parts.length - 1]);
  let secondLastIsNum = parts.length >= 2 ? isNumericToken(parts[parts.length - 2]) : false;
  let foundInMap = false;
  
  if (parts.length >= 3 && lastIsNum && secondLastIsNum) {
    let testModel1 = parts.slice(0, parts.length - 2).join("");
    if (stockMap[normalizeKey(testModel1)]) { p = toNumber(parts.pop()); q = toNumber(parts.pop()); m = parts.join(""); foundInMap = true; }
  }
  
  if (!foundInMap && parts.length >= 2 && lastIsNum) {
    let testModel2 = parts.slice(0, parts.length - 1).join("");
    if (stockMap[normalizeKey(testModel2)]) { q = toNumber(parts.pop()); m = parts.join(""); foundInMap = true; }
  }
  
  if (!foundInMap) m = parts.join("");
  
  let searchStr = normalizeKey(m);
  let match = stockMap[searchStr];
  
  if (!match) return { error: "❌ " + parts.join(" ") + " अभी स्टॉक में अपडेट नहीं है या खत्म हो गया है।" };
  
if (p === 0) {
      let upperTier = (tier || "NORMAL").toUpperCase();
      
      if (isCashSale || upperTier.includes("PREMIUM")) {
          p = match.premiumPrice > 0 ? match.premiumPrice : (match.cashPrice > 0 ? match.cashPrice : match.price);
      } else if (upperTier.includes("SILVER")) {
          p = match.silverPrice > 0 ? match.silverPrice : match.price;
      } else {
          p = match.price;
      }
  }
  p = roundMarketPrice(p);

  if (p < 0) return { error: "❌ " + m + " (रेट गलत है)" };
  
  let finalTotal = q * p;
  let realInventoryCP = q * match.cp; 
  
  return {
    model: match.name, qty: q, price: p, total: finalTotal, profit: finalTotal - realInventoryCP, 
    stock: match.stock, rowIndex: match.rowIndex, universal: match.universal, isSpecial: false
  };
}

function generateOrderListMessage() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const stockSheet = ss.getSheetByName("Live_Stock");
  if (!stockSheet) return "⚠ ERROR: 'Live_Stock' शीट नहीं मिली।";
  
  const stockData = stockSheet.getDataRange().getValues();
  let orderItems = [], totalOrderQty = 0;
  
  for (let ls = 1; ls < stockData.length; ls++) {
    let modelName = (stockData[ls][0] || "").toString().trim();
    if (!modelName) continue;
    
    let currentQty = Number((stockData[ls][1] || "").toString().replace(/[\s,]/g, "")) || 0;
    let thresholdStr = (stockData[ls][5] || "").toString().replace(/[\s,]/g, "");
    let threshold = thresholdStr === "" ? 5 : Number(thresholdStr); 
    
    if (currentQty <= threshold) {
      let orderQty = (threshold >= 5) ? threshold : (threshold - currentQty);
      if (orderQty > 0) {
        orderItems.push({ name: modelName, orderQty: orderQty });
        totalOrderQty += orderQty;
      }
    }
  }
  
  if (orderItems.length === 0) return "✅ सारा स्टॉक लिमिट से ऊपर है। अभी किसी माल की आवश्यकता नहीं है।";
  
  let outputList = [];
  for (let i = 0; i < orderItems.length; i++) {
    outputList.push((i + 1) + ". " + orderItems[i].name + " - " + orderItems[i].orderQty);
  }
  
  let finalMsg = "⚠ *सप्लायर ऑर्डर लिस्ट* ⚠\n\n" + outputList.join("\n") + "\n\n📦 *कुल ऑर्डर Qty:* " + totalOrderQty + " पीस";
  if (orderItems.length > 30) finalMsg += "\n\n@Sattu: यह लिस्ट सप्लायर को डायरेक्ट फॉरवर्ड करो। माल जल्द से जल्द निकलवाओ, स्टॉक भारी शॉर्टेज में है।";
  else finalMsg += "\n\n@Sattu: आज का ऑर्डर फाइनल करो।";
  
  return finalMsg;
}

