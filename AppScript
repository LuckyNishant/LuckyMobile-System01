function serveStock() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Live_Stock');
  if (!sheet) throw new Error('Live_Stock sheet not found');
  const values = sheet.getDataRange().getValues();
  if (values.length < 2) return jsonOutput({ success: true, data: [] });
  const headers = values.shift();
  const data = values.map(row => {
    const obj = {};
    headers.forEach((h, i) => { obj[h] = row[i]; });
    return obj;
  });
  return jsonOutput({ success: true, data });
}

