                  modelName: wData.modelName || "प्राइस ड्रॉप प्रोटेक्शन" 
                });
                
                stockupMutations.wallets++; // Track successful mutation
            } catch(e) {}
        }

       // WRITE PHASE 2.5: EVENT LOGGING (SNAPSHOTS & WALLET MAP)
        if (typeof snapshotRows !== 'undefined' && snapshotRows.length > 0) {
            try {
