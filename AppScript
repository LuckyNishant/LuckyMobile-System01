function getTierRank(tier) {
    let t = (tier || "").toString().toUpperCase();
    if (t.includes("PREMIUM")) return 4;
    if (t.includes("SILVER")) return 3;
    if (t.includes("NORMAL")) return 2;
    if (t.includes("RESTRICTED") || t.includes("BLOCK") || t.includes("DEAD")) return 1;
    return 0;
}

